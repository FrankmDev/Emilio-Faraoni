const demoProducts = getPublicProducts();
const demoProduct = demoProducts[0];

const componentFamilies = [
  {
    id: 'ui',
    label: 'src/components/ui',
    title: 'UI',
    count: 10,
    files: [
      'Badge.astro',
      'Breadcrumbs.astro',
      'Button.astro',
      'CategoryPillList.astro',
      'ContactInfoCard.astro',
      'Container.astro',
      'FeaturedCard.astro',
      'ImagePlaceholder.astro',
      'SectionDivider.astro',
      'SectionHeader.astro',
    ],
  },
  {
    id: 'layout',
    label: 'src/components/layout',
    title: 'Layout',
    count: 4,
    files: ['Header.astro', 'Footer.astro', 'NavLink.astro', 'PageShell.astro'],
  },
  {
    id: 'sections',
    label: 'src/components/sections',
    title: 'Sections',
    count: 9,
    files: [
      'ArticleHeader.astro',
      'B2BAccessBlock.astro',
      'CompanyIntro.astro',
      'FeaturedCategories.astro',
      'FeaturedGrid.astro',
      'FeaturedProducts.astro',
      'FinalCTA.astro',
      'HomeHero.astro',
      'PageHero.astro',
    ],
  },
  {
    id: 'blog',
    label: 'src/components/blog',
    title: 'Blog',
    count: 2,
    files: ['BlogCard.astro', 'BlogGrid.astro'],
  },
  {
    id: 'product',
    label: 'src/components/product',
    title: 'Product',
    count: 6,
    files: [
      'ProductCard.astro',
      'ProductGallery.astro',
      'ProductGrid.astro',
      'ProductInfo.astro',
      'RelatedProducts.astro',
      'RestrictedPriceCTA.astro',
    ],
  },
];

const colorTokens = [
  ['--color-bg', '#f1f0ec', 'Base exterior'],
  ['--color-page', '#fbfaf7', 'Página'],
  ['--color-surface', '#ffffff', 'Superficie'],
  ['--color-surface-soft', '#f5f4f0', 'Plano suave'],
  ['--color-surface-muted', '#ecede9', 'Fondo editorial'],
  ['--color-surface-sand', '#e2e0d8', 'Arena neutra'],
  ['--color-surface-clay', '#d6d3cb', 'Arcilla neutra'],
  ['--color-surface-inverse', '#15110d', 'Bloque oscuro'],
  ['--color-ink', '#141210', 'Tinta'],
  ['--color-ink-soft', '#2e2823', 'Tinta suave'],
  ['--color-muted', '#6c6660', 'Texto secundario'],
  ['--color-leather', '#765033', 'Cuero'],
  ['--color-leather-dark', '#2e1c10', 'Cuero oscuro'],
  ['--color-brass', '#a18458', 'Latón'],
  ['--color-border-soft', '#e8e7e2', 'Hairline'],
  ['--color-border', '#d8d6d0', 'Borde'],
];

const tokenFamilies = [
  {
    id: 'global-tokens-color',
    title: 'Color tokens',
    eyebrow: ':root · color',
    items: colorTokens.map(([token, value, usage]) => ({
      token,
      value,
      usage,
    })),
  },
  {
    id: 'global-tokens-type',
    title: 'Typography tokens',
    eyebrow: ':root · fonts',
    items: [
      {
        token: '--font-display',
        value: 'Fraunces',
        usage: 'Display editorial',
      },
      { token: '--font-serif', value: 'Fraunces', usage: 'Serif base' },
      { token: '--font-sans', value: 'Manrope', usage: 'Texto y UI' },
      {
        token: '--font-mono',
        value: 'JetBrains Mono',
        usage: 'Código y tokens',
      },
    ],
  },
  {
    id: 'global-tokens-layout',
    title: 'Layout tokens',
    eyebrow: ':root · layout',
    items: [
      { token: '--container', value: '77rem', usage: 'Ancho editorial' },
      { token: '--container-wide', value: '92rem', usage: 'Spreads amplios' },
      {
        token: '--container-narrow',
        value: '58rem',
        usage: 'Páginas internas',
      },
      { token: '--container-reading', value: '44rem', usage: 'Lectura' },
      {
        token: '--section-y',
        value: 'clamp(4rem, 7.5vw, 8rem)',
        usage: 'Sección',
      },
      { token: '--grid-gap', value: 'clamp(1rem, 2vw, 1.5rem)', usage: 'Grid' },
    ],
  },
  {
    id: 'global-tokens-shape',
    title: 'Shape, motion and focus',
    eyebrow: ':root · system',
    items: [
      { token: '--radius-xs', value: '2px', usage: 'Control fino' },
      { token: '--radius-card', value: '4px', usage: 'Card editorial' },
      { token: '--radius-card-lg', value: '8px', usage: 'Módulos premium' },
      { token: '--radius-button', value: '999px', usage: 'Botón pill' },
      {
        token: '--ease-out',
        value: 'cubic-bezier(0.16, 1, 0.3, 1)',
        usage: 'Hover',
      },
      {
        token: '--focus-ring-color',
        value: 'cuero oscuro',
        usage: 'Accesibilidad',
      },
    ],
  },
];

