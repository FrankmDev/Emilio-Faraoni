---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..700;1,9..144,100..700&family=Manrope:wght@200..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>Style Museum · Emilio Faraoni</title>
  </head>
  <body>
    <main class="museum">
      <header class="museum-hero">
        <div class="museum-container">
          <div class="museum-hero__rail">
            <span class="eyebrow">Sistema de diseño</span>
            <span class="museum-rule" aria-hidden="true"></span>
            <span class="meta-label">31 componentes · global.css indexado</span>
          </div>
          <div class="museum-hero__grid">
            <div class="museum-hero__copy">
              <h1 class="display-serif museum-hero__title">
                Style <span class="editorial-accent">Museum</span>
              </h1>
              <p class="copy-lead museum-hero__lead">
                Inventario visual de la web de Emilio Faraoni. Todo sigue el
                mismo patrón: familia, nombre exacto, ruta o clase, y una
                muestra real del sistema.
              </p>
            </div>
            <aside class="museum-hero__panel" aria-label="Resumen del sistema">
              <p class="editorial-numeral">01</p>
              <p class="meta-label">Lectura recomendada</p>
              <p class="copy-small">
                Primero componentes por carpeta. Después tokens y clases
                globales de <code>src/styles/global.css</code>.
              </p>
            </aside>
          </div>
          <nav class="museum-nav" aria-label="Navegación del Style Museum">
            <a href="#components">Componentes</a>
            <a href="#family-ui">UI</a>
            <a href="#family-layout">Layout</a>
            <a href="#family-sections">Sections</a>
            <a href="#family-blog">Blog</a>
            <a href="#family-product">Product</a>
            <a href="#globals">Globals</a>
            <a href="#global-tokens">Tokens</a>
            <a href="#global-classes">Clases</a>
          </nav>
        </div>
      </header>

      <section id="components" class="museum-section">
        <div class="museum-container">
          <header class="museum-section__head">
            <span class="museum-section__num">01</span>
            <div>
              <p class="eyebrow">src/components</p>
              <h2 class="heading-section">Componentes por carpeta</h2>
              <p class="copy-lead">
                Inventario completo de componentes Astro, empezando por
                <code>src/components/ui</code>. Cada pieza mantiene su nombre de
                archivo visible y su preview aislada.
              </p>
            </div>
          </header>

          <div class="museum-family-index" aria-label="Resumen de carpetas">
            {
              componentFamilies.map((family) => (
                <a href={`#family-${family.id}`} class="museum-index-card">
                  <span class="meta-label">{family.label}</span>
                  <strong>{family.title}</strong>
                  <span>{family.count} componentes</span>
                </a>
              ))
            }
          </div>

          <div class="museum-directory">
            <section id="family-ui" class="museum-family">
              <header class="museum-family__head">
                <div>
                  <p class="eyebrow">src/components/ui</p>
                  <h3 class="heading-card">UI · 10 componentes</h3>
                </div>
                <p class="copy-small">
                  Primitivas reutilizables para construir páginas y secciones.
                </p>
              </header>
              <div class="museum-file-strip">
                {
                  componentFamilies[0]?.files.map((file) => (
                    <span class="museum-file">{file}</span>
                  ))
                }
              </div>

              <article class="museum-spec">
                <header>
                  <strong>Badge.astro</strong><code
                    >src/components/ui/Badge.astro</code
                  >
                </header>
                <div class="museum-preview museum-preview--inline">
                  <Badge label="Neutral" />
                  <Badge label="Ink" tone="ink" dot />
                  <Badge label="Outline" variant="outline" count="12" />
                  <Badge href="/catalogo" label="Link badge" tone="sand" />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>Breadcrumbs.astro</strong><code
                    >src/components/ui/Breadcrumbs.astro</code
                  >
                </header>
                <div class="museum-preview">
                  <Breadcrumbs
                    context="Catálogo"
                    home
                    separator="diamond"
                    meta="B2B"
                    items={[
                      { label: 'Inicio', href: '/' },
                      { label: 'Catálogo', href: '/catalogo' },
                      { label: 'Cinturones', href: '/catalogo/cinturones' },
                      { label: 'Cinturón de piel clásico' },
                    ]}
                  />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>Button.astro</strong><code
                    >src/components/ui/Button.astro</code
                  >
                </header>
                <div class="museum-preview museum-preview--inline">
                  <Button variant="primary">Solicitar acceso</Button>
                  <Button variant="secondary">Contactar</Button>
                  <Button variant="ghost" iconAfter>Ver más</Button>
                  <Button variant="gold">Destacado</Button>
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>CategoryPillList.astro</strong><code
                    >src/components/ui/CategoryPillList.astro</code
                  > · underline
                </header>
                <div class="museum-preview">
                  <CategoryPillList
                    variant="underline"
                    categories={[
                      { label: 'Todos', href: '/blog' },
                      { label: 'Empresa', href: '/blog/empresa' },
                      { label: 'Marroquinería', href: '/blog/marroquineria' },
                      { label: 'Fabricación', href: '/blog/fabricacion' },
                      { label: 'Materiales', href: '/blog/materiales' },
                      { label: 'Sector', href: '/blog/sector' },
                    ]}
                    active="Materiales"
                  />
                </div>
              </article>
              <article class="museum-spec">
                <header>
                  <strong>CategoryPillList.astro</strong><code
                    >src/components/ui/CategoryPillList.astro</code
                  > · bordered
                </header>
                <div class="museum-preview">
                  <CategoryPillList
                    variant="bordered"
                    withIndex
                    categories={[
                      { label: 'Todos', href: '/catalogo' },
                      { label: 'Cinturones', href: '/catalogo/cinturones' },
                      { label: 'Bolsos', href: '/catalogo/bolsos' },
                      { label: 'Carteras', href: '/catalogo/carteras' },
                    ]}
                    active="Cinturones"
                  />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>ContactInfoCard.astro</strong><code
                    >src/components/ui/ContactInfoCard.astro</code
                  >
                </header>
                <div class="museum-preview museum-preview--grid-2">
                  <ContactInfoCard
                    index="01"
                    label="Email comercial"
                    value="ventas@emiliofaraoni.com"
                    href="mailto:ventas@emiliofaraoni.com"
                    description="Atención directa para clientes mayoristas."
                    variant="frame"
                  />
                  <ContactInfoCard
                    index="02"
                    label="Ubicación"
                    value="Elche, Alicante"
                    description="Fabricación y showroom con visita concertada."
                    variant="frame"
                  />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>Container.astro</strong><code
                    >src/components/ui/Container.astro</code
                  >
                </header>
                <div class="museum-preview museum-preview--flush">
                  <Container
                    framed
                    density="compact"
                    class="museum-demo-container"
                  >
                    <p class="meta-label">Container default framed</p>
                    <p class="copy-small">
                      Primitiva de ancho y padding usada por layout y secciones.
                    </p>
                  </Container>
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>FeaturedCard.astro</strong><code
                    >src/components/ui/FeaturedCard.astro</code
                  >
                </header>
                <div class="museum-preview museum-preview--grid-2">
                  <FeaturedCard
                    index={1}
                    eyebrow="Oficio"
                    title="Empresa familiar"
                    description="Trayectoria de marroquinería en Elche desde 1988."
                  />
                  <FeaturedCard
                    index={2}
                    href="/empresa"
                    eyebrow="Producto"
                    title="Fabricación nacional"
                    description="Control de materiales, acabados y continuidad comercial."
                  />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>ImagePlaceholder.astro</strong><code
                    >src/components/ui/ImagePlaceholder.astro</code
                  >
                </header>
                <div class="museum-preview museum-preview--grid-4">
                  <ImagePlaceholder variant="wide" label="Wide" />
                  <ImagePlaceholder variant="portrait" label="Portrait" />
                  <ImagePlaceholder variant="square" label="Square" />
                  <ImagePlaceholder variant="hero" tone="light" label="Hero" />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>SectionDivider.astro</strong><code
                    >src/components/ui/SectionDivider.astro</code
                  >
                </header>
                <div class="museum-preview">
                  <SectionDivider label="Capítulo de muestra" />
                  <SectionDivider spacing="compact" tone="leather" marks />
                </div>
              </article>

              <article class="museum-spec">
                <header>
                  <strong>SectionHeader.astro</strong><code
                    >src/components/ui/SectionHeader.astro</code
                  >
                </header>
                <div class="museum-preview">
                  <SectionHeader
                    index="08"
                    eyebrow="Sistema"
                    kicker="Catálogo"
                    meta="B2B"
                    title="Cabecera editorial de sección"
                    description="Componente base para abrir bloques de contenido con jerarquía clara."
                  >
                    <Button slot="action" variant="secondary">Acción</Button>
                  </SectionHeader>
                </div>
              </article>
            </section>

            <section id="family-layout" class="museum-family">
              <header class="museum-family__head">
                <div>
                  <p class="eyebrow">src/components/layout</p>
                  <h3 class="heading-card">Layout · 4 componentes</h3>
                </div>
                <p class="copy-small">
                  Estructura principal de página y navegación.
                </p>
              </header>
              <div class="museum-file-strip">
                {
                  componentFamilies[1]?.files.map((file) => (
                    <span class="museum-file">{file}</span>
                  ))
                }
              </div>

              <article class="museum-spec">
                <header>
                  <strong>Header.astro</strong><code
                    >src/components/layout/Header.astro</code
                  >
                </header>
                <div
                  class="museum-preview museum-preview--flush museum-preview--header"
                >
                  <Header />
                </div>
              </article>
              <article class="museum-spec">
                <header>
                  <strong>Footer.astro</strong><code
                    >src/components/layout/Footer.astro</code
                  >
                </header>
                <div
                  class="museum-preview museum-preview--flush museum-preview--scroll"
                >
