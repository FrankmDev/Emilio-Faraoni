        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
        gap: var(--grid-gap);
        margin-bottom: clamp(3rem, 6vw, 5rem);
      }

      .museum-index-card {
        display: grid;
        gap: 0.55rem;
        padding: 1.2rem;
        border: 1px solid var(--color-border-soft);
        background: var(--color-surface);
        border-radius: var(--radius-card);
      }

      .museum-section--dark .museum-index-card {
        border-color: color-mix(in srgb, var(--color-inverse) 14%, transparent);
        background: color-mix(in srgb, var(--color-inverse) 5%, transparent);
      }

      .museum-index-card strong {
        color: var(--color-ink);
        font-family: var(--font-display);
        font-size: 1.55rem;
        font-weight: 300;
      }

      .museum-section--dark .museum-index-card strong {
        color: var(--color-inverse);
      }

      .museum-index-card span:last-child {
        font-size: 0.78rem;
      }

      .museum-directory {
        display: grid;
        gap: clamp(3rem, 6vw, 5rem);
      }

      .museum-family {
        display: grid;
        gap: 1.25rem;
        scroll-margin-top: 2rem;
      }

      .museum-family__head {
        grid-template-columns: minmax(0, 1fr);
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--color-border-soft);
      }

      @media (min-width: 56rem) {
        .museum-family__head {
          grid-template-columns: minmax(0, 0.8fr) minmax(16rem, 0.4fr);
          align-items: end;
        }
      }

      .museum-section--dark .museum-family__head {
        border-color: color-mix(in srgb, var(--color-inverse) 16%, transparent);
      }

      .museum-file-strip,
      .museum-class-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }

      .museum-file,
      .museum-class-list code {
        display: inline-flex;
        border: 1px solid var(--color-border-soft);
        background: color-mix(in srgb, var(--color-surface) 82%, transparent);
        color: var(--color-muted);
        border-radius: var(--radius-pill);
        padding: 0.45rem 0.7rem;
        font-family: var(--font-mono);
        font-size: 0.67rem;
      }

      .museum-section--dark .museum-class-list code {
        border-color: color-mix(in srgb, var(--color-inverse) 14%, transparent);
        background: color-mix(in srgb, var(--color-inverse) 6%, transparent);
        color: color-mix(in srgb, var(--color-inverse) 74%, transparent);
      }

      .museum-spec,
      .museum-global-spec,
      .museum-token-family {
        overflow: hidden;
        border: 1px solid var(--color-border-soft);
        border-radius: var(--radius-card);
        background: var(--color-surface);
      }

      .museum-spec > header {
        grid-template-columns: minmax(0, 0.75fr) minmax(0, 1fr);
        align-items: baseline;
        padding: 1.1rem clamp(1rem, 2vw, 1.5rem);
        border-bottom: 1px solid var(--color-border-soft);
        background: var(--color-surface-muted);
      }

      .museum-spec strong {
        color: var(--color-ink);
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2vw, 1.85rem);
        font-weight: 300;
      }

      .museum-spec code {
        color: var(--color-muted);
        text-align: right;
        overflow-wrap: anywhere;
      }

      .museum-preview {
        padding: clamp(1.25rem, 2vw, 1.75rem);
        background: var(--color-bg);
        overflow: hidden;
      }

      .museum-preview--flush {
        padding: 0;
      }

      .museum-preview--inline {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
      }

      .museum-preview--grid-2,
      .museum-preview--grid-4 {
        display: grid;
        gap: var(--grid-gap);
      }

      .museum-preview--grid-2 {
        grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      }

      .museum-preview--grid-4 {
        grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
      }

      .museum-preview--narrow {
        max-width: 30rem;
      }

      .museum-preview--scroll {
        max-height: 36rem;
        overflow: auto;
        overscroll-behavior: contain;
      }

      .museum-preview--header :global(header) {
        position: relative;
        top: auto;
      }

      .museum-demo-container {
        padding-block: 2rem;
      }

      .museum-demo-shell {
        min-height: 12rem;
        display: grid;
        align-content: center;
        gap: 0.75rem;
        padding: clamp(2rem, 4vw, 4rem);
        background: var(--color-bg);
      }

      .museum-nav-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem 2.25rem;
      }

      .museum-token-sections {
        display: grid;
        gap: var(--grid-gap);
      }

      .museum-token-family {
        padding: clamp(1.25rem, 2vw, 1.75rem);
        background: color-mix(in srgb, var(--color-inverse) 4%, transparent);
        border-color: color-mix(in srgb, var(--color-inverse) 14%, transparent);
      }

      .museum-token-family header {
        display: grid;
        gap: 0.4rem;
        margin-bottom: 1rem;
      }

      .museum-token-family h4,
      .museum-global-spec h4 {
        margin: 0;
        color: var(--color-inverse);
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2vw, 1.8rem);
        font-weight: 300;
      }

      .museum-token-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
        gap: 0.75rem;
      }

      .museum-token-grid--color {
        grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
      }

      .museum-token {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 0.35rem 0.75rem;
        align-items: center;
        min-height: 4.5rem;
        padding: 0.85rem;
        border: 1px solid
          color-mix(in srgb, var(--color-inverse) 12%, transparent);
        background: color-mix(in srgb, var(--color-inverse) 5%, transparent);
        border-radius: var(--radius-card);
      }

      .museum-token__swatch {
        grid-row: span 3;
        width: 2.4rem;
        height: 2.4rem;
        border: 1px solid
          color-mix(in srgb, var(--color-inverse) 24%, transparent);
        border-radius: 50%;
      }

      .museum-token code {
        color: var(--color-inverse);
      }

      .museum-token span,
      .museum-token small {
        color: color-mix(in srgb, var(--color-inverse) 68%, transparent);
      }

      .museum-global-spec {
        display: grid;
        gap: 0;
        background: color-mix(in srgb, var(--color-inverse) 4%, transparent);
        border-color: color-mix(in srgb, var(--color-inverse) 14%, transparent);
      }

      .museum-global-spec__head {
        grid-template-columns: minmax(0, 1fr) auto;
        padding: 1.25rem;
        border-bottom: 1px solid
          color-mix(in srgb, var(--color-inverse) 12%, transparent);
      }

      .museum-global-spec__head p {
        max-width: 68ch;
        margin: 0.65rem 0 0;
        color: color-mix(in srgb, var(--color-inverse) 68%, transparent);
        font-size: 0.9rem;
        line-height: 1.65;
      }

      .museum-global-spec__head strong {
        color: var(--color-gold-soft);
        font-family: var(--font-display);
        font-size: 2rem;
        font-weight: 300;
      }

      .museum-class-list {
        padding: 1.25rem;
        border-bottom: 1px solid
          color-mix(in srgb, var(--color-inverse) 12%, transparent);
      }

      .museum-global-preview {
        padding: 1.25rem;
      }

      .museum-layout-demo,
      .museum-media-demo {
        display: grid;
        gap: 1rem;
      }

      .museum-layout-demo .grid span,
      .museum-layout-demo .split span {
        min-height: 4rem;
        border: 1px solid
          color-mix(in srgb, var(--color-inverse) 16%, transparent);
        background: color-mix(in srgb, var(--color-inverse) 8%, transparent);
        border-radius: var(--radius-card);
      }

      .museum-surface-demo > * {
        min-height: 7rem;
        display: grid;
        place-items: center;
        padding: 1rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .museum-global-preview .display-soft {
        margin: 0;
      }

      .museum-global-preview .feature-card {
        max-width: 28rem;
        background: var(--color-surface);
        color: var(--color-ink);
      }

      .museum-media-demo .image-placeholder {
        display: grid;
        place-items: center;
        min-height: 9rem;
        border: 1px solid
          color-mix(in srgb, var(--color-inverse) 14%, transparent);
        background: color-mix(in srgb, var(--color-inverse) 6%, transparent);
        color: color-mix(in srgb, var(--color-inverse) 70%, transparent);
      }

      .museum-media-demo .divider-editorial {
        background: color-mix(in srgb, var(--color-inverse) 16%, transparent);
      }

      .museum-footer {
        padding-block: 2.75rem;
        border-top: 1px solid var(--color-border-soft);
        background: var(--color-surface);
        text-align: center;
      }

      @media (max-width: 760px) {
        .museum-container {
          width: auto;
          max-width: 100vw;
          margin-inline: 1rem;
          padding-inline: 0;
        }

        .museum-hero__lead,
        .museum-hero__panel {
          max-width: calc(100vw - 4rem);
        }

        .museum-hero__lead {
          max-width: 29ch;
        }

        .museum-hero__rail,
        .museum-section__head,
        .museum-spec > header,
        .museum-global-spec__head {
          grid-template-columns: 1fr;
        }

        .museum-nav {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .museum-spec code {
          text-align: left;
        }
      }
    </style>
  </body>
</html>
