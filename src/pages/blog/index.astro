---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageShell from '@/components/layout/PageShell.astro';
---

<BaseLayout
  title="Blog"
  description="Artículos sobre marroquinería, fabricación artesanal, materiales y producto. Notas editoriales de Emilio Faraoni."
>
  <PageShell>
    <section class="page-hero" aria-labelledby="blog-title">
      <div class="container-wide page-hero-inner">
        <div class="page-hero-content">
          <p class="page-hero__eyebrow eyebrow">Blog</p>
          <h1 id="blog-title" class="page-hero__title display-serif">
            Blog
          </h1>
          <p class="page-hero__description copy-lead">
            Artículos sobre marroquinería, fabricación, materiales y producto.
          </p>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
