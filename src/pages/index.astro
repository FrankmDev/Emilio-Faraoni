---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageShell from '@/components/layout/PageShell.astro';
import { company } from '@/data/company';
---

<BaseLayout
  title="Inicio"
  description={`${company.shortDescription} Conoce la marca, su trayectoria y su forma de entender la marroquinería.`}
>
  <PageShell>
    <section class="page-hero" aria-labelledby="home-title">
      <div class="container-wide page-hero-inner">
        <div class="page-hero-content">
          <p class="page-hero__eyebrow eyebrow">Inicio · {company.foundedYear}</p>
          <h1 id="home-title" class="page-hero__title display-serif">
            {company.name}
          </h1>
          <p class="page-hero__description copy-lead">
            Fabricación artesanal de cinturones, bolsos y complementos de
            cuero desde 1988.
          </p>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
