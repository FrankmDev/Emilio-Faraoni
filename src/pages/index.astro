---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageShell from '@/components/layout/PageShell.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import { ROUTES } from '@/lib/routes';
---

<BaseLayout title="Arquitectura inicial">
  <PageShell>
    <section class="py-16 md:py-24">
      <Container class="grid gap-8">
        <SectionHeader
          eyebrow="Fase 1"
          title="Base Astro para catálogo B2B"
          description="Arquitectura inicial, datos centralizados y componentes mínimos para preparar el futuro catálogo mayorista de Emilio Faraoni."
        />

        <div class="flex flex-wrap gap-3">
          <Button href={ROUTES.CATALOG}>Ruta catálogo</Button>
          <Button href={ROUTES.WHOLESALE_ACCESS} variant="secondary"
            >Acceso mayorista</Button
          >
        </div>

        <div class="rounded-sm border border-border bg-surface p-6">
          <h2 class="text-xl font-semibold text-ink">Alcance actual</h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-muted">
            Esta pantalla solo verifica layout, estilos, navegación y
            componentes base. No hay login, Supabase, carrito, emails, panel
            admin ni catálogo completo.
          </p>
        </div>
      </Container>
    </section>
  </PageShell>
</BaseLayout>
