---
import type { PublicProduct } from '@/lib/products/getters';
import ProductCard from './ProductCard.astro';

interface Props {
  products: PublicProduct[];
}

const { products } = Astro.props;
---

{
  products.length > 0 && (
    <section class="section-y-compact border-t border-border-hairline">
      <div class="mb-12 flex items-end justify-between gap-6">
        <div>
          <p class="eyebrow">Catálogo</p>
          <h2 class="heading-section mt-4 text-ink">Productos relacionados</h2>
        </div>
        <span
          class="hidden h-px w-24 bg-border-strong md:block"
          aria-hidden="true"
        />
      </div>
      <div class="grid gap-x-grid-gap gap-y-14 md:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </section>
  )
}
