---
import type { PublicProduct } from '@/lib/products/getters';

interface Props {
  product: PublicProduct;
}

const { product } = Astro.props;
const primaryImage = product.images[0];
---

<div class="grid gap-3">
  {
    primaryImage ? (
      <img
        src={primaryImage}
        alt={`${product.name} Emilio Faraoni`}
        class="aspect-[4/5] w-full rounded-card border border-border-soft bg-surface-muted object-cover"
      />
    ) : (
      <div
        class="product-surface aspect-[4/5] border border-border-soft"
        aria-label={product.name}
      />
    )
  }
</div>
