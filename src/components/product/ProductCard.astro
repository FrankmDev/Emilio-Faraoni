---
/**
 * ProductCard · editorial retail product card.
 *
 * 80% image, 20% information. The photo is the protagonist.
 * No card chrome, no border, no SaaS surface. Below the
 * image: a tiny category line, the product name in sans
 * (Zara / Mango / COS), and a one-line meta strip with
 * reference + a discreet "precio bajo solicitud" hint.
 *
 * Optional `featured` variant switches the layout to a
 * side-by-side composition (image left, info right) used
 * for the first product in a retail grid.
 *
 * Always use the public getters from `src/lib/products/getters.ts`
 * to render — never import raw `products` here, so private
 * fields like `wholesalePrice` never leak into the DOM.
 */
import type { PublicProduct } from '@/lib/products/getters';
import { ROUTES } from '@/lib/routes';
import ImagePlaceholder from '@/components/ui/ImagePlaceholder.astro';

interface Props {
  product: PublicProduct;
  /** Featured layout — spans 2 columns, image + info
   *  side-by-side on desktop. */
  featured?: boolean;
  /** Override loading strategy. First card on a page
   *  should be eager. */
  priority?: boolean;
  /** Optional index for the corner stamp. Defaults to the
   *  reference id (e.g. "EF-001"). */
  index?: string;
  /** Hide the hover quick-action overlay. */
  hideQuickAction?: boolean;
  class?: string;
}

const {
  product,
  featured = false,
  priority = false,
  index,
  hideQuickAction = false,
  class: className,
} = Astro.props;

const productHref = `${ROUTES.CATALOG}/${product.categorySlug}/${product.slug}`;
const primaryImage = product.images[0];
const visibleColors = product.colors.slice(0, 4);
const extraColors = Math.max(0, product.colors.length - visibleColors.length);
const stampLabel = index ?? product.reference ?? null;

const classes = [
  'product-card',
  featured && 'product-card--featured',
  className,
]
  .filter(Boolean)
  .join(' ');

const loadingStrategy = priority ? 'eager' : 'lazy';
const fetchPriority = priority ? 'high' : 'auto';
---

<article class={classes}>
  <figure class="product-card__media">
    {
      primaryImage ? (
        <img
          src={primaryImage}
          alt={`${product.name} · Emilio Faraoni`}
          loading={loadingStrategy}
          decoding="async"
          fetchpriority={fetchPriority}
        />
      ) : (
        <ImagePlaceholder
          variant="portrait"
          tone="muted"
          frame="minimal"
          label={product.reference ?? product.category}
          kicker="Emilio Faraoni"
        />
      )
    }
    {
      !featured && (
        <div class="product-card__media-top" aria-hidden="true">
          {stampLabel && (
            <span class="product-card__stamp">
              N° {stampLabel.replace(/^EF-?/i, '')}
            </span>
          )}
          {!hideQuickAction && (
            <span class="product-card__quick">Vista rápida</span>
          )}
        </div>
      )
    }
  </figure>

  <div class="product-card__body">
    <p class="product-card__category">{product.category}</p>
    <h3 class="product-card__name">
      <a href={productHref} class="product-card__name-link">
        {product.name}
      </a>
    </h3>
    <p class="product-card__meta">
      {
        product.reference && (
          <>
            <span class="product-card__ref">Ref. {product.reference}</span>
            <span class="product-card__meta-sep" aria-hidden="true">
              ·
            </span>
          </>
        )
      }
      <span class="product-card__price-hint">Precio bajo solicitud</span>
    </p>
    {
      visibleColors.length > 0 && !featured && (
        <div class="product-card__swatches" aria-label="Colores disponibles">
          {visibleColors.map((color) => (
            <span
              class="product-card__swatch"
              title={color}
              aria-label={color}
            />
          ))}
          {extraColors > 0 && (
            <span class="product-card__swatch-more">+{extraColors}</span>
          )}
        </div>
      )
    }
    <span class="product-card__hairline" aria-hidden="true"></span>
  </div>

  {
    /* Single click target: the name link in the body is the
      focusable element; the `.click-area` overlay extends the
      hit area across the whole card. */
  }
  <a
    href={productHref}
    class="click-area product-card__link"
    aria-label={`Ver ficha de ${product.name}`}
    tabindex="-1"></a>
</article>
