---
import type { PublicProduct } from '@/lib/products/getters';
import Badge from '@/components/ui/Badge.astro';
import { ROUTES } from '@/lib/routes';

interface Props {
  product: PublicProduct;
}

const { product } = Astro.props;
const productHref = `${ROUTES.CATALOG}/${product.categorySlug}/${product.slug}`;
const primaryImage = product.images[0];
const visibleColors = product.colors.slice(0, 3);
---

<article class="group grid gap-5">
  <a
    href={productHref}
    class="image-ground relative block aspect-[4/5] overflow-hidden border border-border-hairline"
    aria-label={`Ver ficha de ${product.name}`}
  >
    {
      primaryImage ? (
        <img
          src={primaryImage}
          alt={`${product.name} Emilio Faraoni`}
          class="h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.025]"
          loading="lazy"
        />
      ) : (
        <div class="absolute inset-[13%] border border-border-strong bg-surface-accent shadow-[var(--shadow-soft)]" />
      )
    }
    <span
      class="absolute left-4 top-4 bg-ink px-3 py-1.5 text-[0.58rem] font-medium uppercase tracking-[0.18em] text-ink-on-inverse"
    >
      {product.category}
    </span>
    <span
      class="absolute bottom-4 right-4 h-px w-12 bg-ink transition-all duration-500 group-hover:w-20"
      aria-hidden="true"></span>
  </a>
  <div class="grid gap-3">
    <div class="flex items-center justify-between gap-4">
      <Badge
        label={product.reference
          ? `Ref. ${product.reference}`
          : product.category}
      />
      <span class="text-[0.62rem] uppercase tracking-[0.18em] text-muted">
        Precio privado
      </span>
    </div>
    <h3 class="heading-card text-ink">
      <a
        href={productHref}
        class="transition-colors duration-300 hover:text-leather-dark"
      >
        {product.name}
      </a>
    </h3>
    <p class="copy-small">{product.shortDescription}</p>
    <div class="flex flex-wrap items-center gap-2 pt-1">
      {
        visibleColors.map((color) => (
          <span class="border border-border-hairline bg-surface px-2.5 py-1 text-[0.62rem] text-muted">
            {color}
          </span>
        ))
      }
    </div>
  </div>
</article>
