---
import type { PublicProduct } from '@/lib/products/types';
import Badge from '@/components/ui/Badge.astro';
import { ROUTES } from '@/lib/routes';

interface Props {
  product: PublicProduct;
}

const { product } = Astro.props;
---

<article class="group grid gap-4">
  <a
    href={`${ROUTES.CATALOG}/${product.categorySlug}/${product.slug}`}
    class="surface-muted block aspect-[4/5] overflow-hidden"
  >
    <div class="h-full w-full bg-surface-muted"></div>
  </a>
  <div>
    <Badge label={product.category} />
    <h3 class="font-serif text-xl font-light tracking-[-0.01em] text-ink">
      <a
        href={`${ROUTES.CATALOG}/${product.categorySlug}/${product.slug}`}
        class="transition-colors hover:text-ink-soft"
      >
        {product.name}
      </a>
    </h3>
    <p class="copy-small mt-2">{product.shortDescription}</p>
    <p class="meta-label mt-4">
      Ref. {product.reference}
    </p>
  </div>
</article>
