---
/**
 * ProductInfo · editorial product B2B page block.
 * Two-column composition: media on the left, body on the
 * right. Soft surface, generous radius, no top/bottom hard
 * rules, no chip underlines. Definition list uses hairline
 * internal separators only — the surrounding box has no
 * border so it reads as a continuous catalogue spread.
 */
import type { PublicProduct } from '@/lib/products/getters';
import Container from '@/components/ui/Container.astro';
import RestrictedPriceCTA from './RestrictedPriceCTA.astro';

interface Props {
  product: PublicProduct;
}

const { product } = Astro.props;
const primaryImage = product.images[0];
const galleryImages = product.images.slice(0, 4);

type Spec = { term: string; detail?: string; chips?: string[] };
const specs: Spec[] = [
  ...(product.colors.length > 0
    ? [{ term: 'Colores', chips: product.colors }]
    : []),
  ...(product.sizes.length > 0
    ? [{ term: 'Tallas', chips: product.sizes }]
    : []),
  ...(product.measurements
    ? [{ term: 'Medidas', detail: product.measurements }]
    : []),
  ...(product.materials
    ? [{ term: 'Materiales', detail: product.materials }]
    : []),
];
---

<section class="section">
  <Container class="product-info">
    <div class="product-info__media">
      {
        primaryImage ? (
          <figure class="product-info__media-main">
            <img
              src={primaryImage}
              alt={`${product.name} Emilio Faraoni`}
              loading="eager"
              decoding="async"
            />
          </figure>
        ) : (
          <div
            class="product-info__media-main product-info__media-main--placeholder"
            aria-label={product.name}
          />
        )
      }
      {
        galleryImages.length > 1 && (
          <div class="product-info__media-thumbs">
            {galleryImages.map((src, i) => (
              <div class="product-info__media-thumb">
                <img
                  src={src}
                  alt={`${product.name} detalle ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
        )
      }
    </div>

    <div class="product-info__body">
      <p class="eyebrow product-info__eyebrow">{product.category}</p>

      <h1 class="product-info__title">{product.name}</h1>

      {
        product.reference && (
          <p class="product-info__ref">Ref. {product.reference}</p>
        )
      }

      <p class="product-info__lead">{product.description}</p>

      {
        specs.length > 0 && (
          <dl class="product-info__spec">
            {specs.map((spec) => (
              <div class="product-info__spec-row">
                <dt class="product-info__spec-term">{spec.term}</dt>
                <dd class="product-info__spec-detail">
                  {spec.chips ? (
                    <ul class="product-info__chip-group" role="list">
                      {spec.chips.map((chip) => (
                        <li>
                          <span class="product-info__chip">{chip}</span>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    spec.detail
                  )}
                </dd>
              </div>
            ))}
          </dl>
        )
      }

      <RestrictedPriceCTA class="product-info__cta" />
    </div>
  </Container>
</section>

<style>
  /* All visual tokens for .product-info live in
     src/styles/global.css. This block only contains
     component-level adjustments that depend on context. */

  .product-info__cta {
    margin-top: 0.6rem;
  }
</style>
