---
import type { PublicProduct } from '@/lib/products/types';
import Button from '@/components/ui/Button.astro';
import { ROUTES } from '@/lib/routes';

interface Props {
  product: PublicProduct;
}

const { product } = Astro.props;
const primaryImage = product.images[0];
---

<section class="section-y">
  <div class="grid gap-12">
    <div>
      {
        primaryImage ? (
          <img
            src={primaryImage}
            alt={`${product.name} Emilio Faraoni`}
            class="aspect-[4/5] w-full border border-border-soft object-cover"
          />
        ) : (
          <div
            class="aspect-[4/5] border border-border-soft bg-surface-muted"
            aria-label={product.name}
          />
        )
      }
    </div>
    <div class="grid gap-3">
      <h1 class="font-serif text-3xl font-light tracking-[-0.02em] text-ink md:text-4xl">
        {product.name}
      </h1>
      <p class="meta-label">
        Ref. {product.reference}
      </p>
      <p class="copy-lead mt-4 max-w-2xl">
        {product.description}
      </p>
      <div class="mt-8 grid gap-3 border-y border-border-soft py-5 text-sm">
        <div class="grid gap-1 sm:grid-cols-[8rem_1fr]">
          <dt class="meta-label">Colores</dt>
          <dd class="text-muted">{product.colors.join(', ')}</dd>
        </div>
        <div class="grid gap-1 sm:grid-cols-[8rem_1fr]">
          <dt class="meta-label">Tallas</dt>
          <dd class="text-muted">{product.sizes.join(', ')}</dd>
        </div>
        {
          product.measurements && (
            <div class="grid gap-1 sm:grid-cols-[8rem_1fr]">
              <dt class="meta-label">Medidas</dt>
              <dd class="text-muted">{product.measurements}</dd>
            </div>
          )
        }
        {
          product.materials && (
            <div class="grid gap-1 sm:grid-cols-[8rem_1fr]">
              <dt class="meta-label">Materiales</dt>
              <dd class="text-muted">{product.materials}</dd>
            </div>
          )
        }
      </div>
      <p class="meta-label mt-6 text-ink">
        Precio disponible para clientes mayoristas registrados.
      </p>
      <p class="copy-small mt-2">
        Solicite acceso profesional para consultar tarifas y condiciones.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <Button href={ROUTES.WHOLESALE_ACCESS}>Solicitar acceso mayorista</Button>
        <Button href={ROUTES.CONTACT} variant="secondary">
          Contactar con ventas
        </Button>
      </div>
    </div>
  </div>
</section>
