---
/**
 * ProductInfo · editorial product detail body.
 *
 * Two-column composition: media on the left, body on the
 * right. Reads as a professional catalogue spread — soft
 * surface, generous radius, no top/bottom hard rules, no
 * chip underlines.
 *
 * The body carries the same hierarchy as a printed
 * catalogue page: eyebrow, big serif title, reference
 * with a hairline prefix, lead description, italic
 * materials line, a soft spec list, and the commercial
 * CTA slot. Everything lives in `src/styles/global.css`
 * under `.product-info*` and `.price-cta*`.
 */
import type { PublicProduct } from '@/lib/products/getters';
import Container from '@/components/ui/Container.astro';
import ImagePlaceholder from '@/components/ui/ImagePlaceholder.astro';
import RestrictedPriceCTA from './RestrictedPriceCTA.astro';

type Spec = { term: string; detail?: string; chips?: string[] };

interface Props {
  product: PublicProduct;
  /** Optional override of the restricted price CTA. When
   *  false, the commercial block is omitted (e.g. for
   *  pages where pricing is handled elsewhere). */
  withCommercialCta?: boolean;
  class?: string;
}

const { product, withCommercialCta = true, class: className } = Astro.props;

const specs: Spec[] = [
  ...(product.colors.length > 0
    ? [{ term: 'Colores', chips: product.colors }]
    : []),
  ...(product.sizes.length > 0
    ? [{ term: 'Tallas', chips: product.sizes }]
    : []),
  ...(product.measurements
    ? [{ term: 'Medidas', detail: product.measurements }]
    : []),
];

const detailItems = [
  { label: 'Categoría', value: product.category },
  ...(product.reference
    ? [{ label: 'Referencia', value: `Ref. ${product.reference}` }]
    : []),
  { label: 'Origen', value: 'Fabricación nacional · Elche' },
];

const galleryImages = product.images.slice(0, 5);
const primaryImage = galleryImages[0];

const wrapperClass = ['product-info', className].filter(Boolean).join(' ');
---

<section class="section">
  <Container class={wrapperClass}>
    <div class="product-info__media">
      {
        primaryImage ? (
          <figure class="product-info__media-main">
            <img
              src={primaryImage}
              alt={`${product.name} · Emilio Faraoni`}
              loading="eager"
              decoding="async"
            />
          </figure>
        ) : (
          <div
            class="product-info__media-main product-info__media-main--placeholder"
            aria-label={product.name}
          >
            <ImagePlaceholder
              variant="portrait"
              tone="muted"
              frame="editorial"
              label={product.reference ?? product.category}
              kicker="Emilio Faraoni"
            />
          </div>
        )
      }
      {
        galleryImages.length > 1 && (
          <div class="product-info__media-thumbs">
            {galleryImages.map((src, i) => (
              <div class="product-info__media-thumb">
                <img
                  src={src}
                  alt={`${product.name} detalle ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
        )
      }
    </div>

    <div class="product-info__body">
      <p class="eyebrow product-info__eyebrow">{product.category}</p>

      <h1 class="product-info__title">{product.name}</h1>

      {
        product.reference && (
          <p class="product-info__ref">Ref. {product.reference}</p>
        )
      }

      <p class="product-info__lead">{product.description}</p>

      {
        product.materials && (
          <p class="product-info__materials">{product.materials}</p>
        )
      }

      {
        specs.length > 0 && (
          <dl class="product-info__spec">
            {specs.map((spec) => (
              <div class="product-info__spec-row">
                <dt class="product-info__spec-term">{spec.term}</dt>
                <dd class="product-info__spec-detail">
                  {spec.chips ? (
                    <ul class="product-info__chip-group" role="list">
                      {spec.chips.map((chip) => (
                        <li>
                          <span class="product-info__chip">{chip}</span>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    spec.detail
                  )}
                </dd>
              </div>
            ))}
          </dl>
        )
      }

      <ul class="product-info__detail" aria-label="Ficha técnica">
        {
          detailItems.map((item) => (
            <li class="product-info__detail-item">
              <span class="product-info__detail-label">{item.label}</span>
              <span class="product-info__detail-value">{item.value}</span>
            </li>
          ))
        }
      </ul>

      {withCommercialCta && <RestrictedPriceCTA class="product-info__cta" />}
    </div>
  </Container>
</section>
