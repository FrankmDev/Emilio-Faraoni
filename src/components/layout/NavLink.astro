---
/**
 * NavLink · thin wrapper around the global `.nav-link` class.
 *
 * Renders an uppercase, hairline-revealed link that matches
 * the editorial retail navigation rail. Active state is
 * expressed both via `aria-current="page"` (for assistive
 * tech) and a paired `.is-active` class so the global styles
 * can pin the underline without relying on the attribute
 * alone.
 */
interface Props {
  href: string;
  label: string;
  active?: boolean;
  class?: string;
}

const { href, label, active = false, class: className } = Astro.props;

const classes = ['nav-link', active && 'is-active', className]
  .filter(Boolean)
  .join(' ');
---

<a
  href={href}
  class={classes}
  aria-current={active ? 'page' : undefined}
>
  {label}
</a>
