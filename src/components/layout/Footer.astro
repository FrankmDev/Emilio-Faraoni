---
import Container from '@/components/ui/Container.astro';
import { ROUTES } from '@/lib/routes';

const webItems = [
  { href: ROUTES.HOME, label: 'Inicio' },
  { href: ROUTES.CATALOG, label: 'Catálogo' },
  { href: ROUTES.COMPANY, label: 'Empresa' },
  { href: ROUTES.CONTACT, label: 'Contacto' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <Container
    class="grid grid-cols-2 gap-x-8 gap-y-12 py-16 md:grid-cols-[1.5fr_1fr_1fr] md:gap-12"
  >
    <div class="site-footer__brand col-span-2 md:col-span-1">
      <a href={ROUTES.HOME} class="site-footer__logo">Emilio Faraoni</a>
      <address class="site-footer__address">
        Partida de Matola, Polígono 1, Nave 14<br />
        03294 Elche, Alicante — España
      </address>
    </div>

    <div class="site-footer__col">
      <p class="meta-label">Web</p>
      <ul class="site-footer__list">
        {
          webItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="site-footer__col">
      <p class="meta-label">Contacto</p>
      <ul class="site-footer__list">
        <li>
          <a href="mailto:info@emiliofaraoni.com">info@emiliofaraoni.com</a>
        </li>
        <li>
          <a href="tel:+34965000000">+34 965 000 000</a>
        </li>
        <li class="site-footer__hours">L–V · 9:00–18:00 CET</li>
      </ul>
    </div>
  </Container>

  <div class="site-footer__bottom">
    <Container
      class="flex flex-col items-start gap-2 py-6 text-[0.72rem] text-muted md:flex-row md:items-center md:justify-between md:gap-4"
    >
      <span>© {currentYear} Emilio Faraoni</span>
      <span>Catálogo profesional sin precios públicos</span>
    </Container>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border-hairline);
  }

  .site-footer__logo {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    line-height: 1;
  }

  .site-footer__address {
    display: block;
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-style: normal;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }

  .site-footer__list a {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 200ms var(--ease-soft, ease);
  }

  .site-footer__list a:hover {
    color: var(--color-ink);
  }

  .site-footer__hours {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.3rem;
  }

  .site-footer__bottom {
    border-top: 1px solid var(--color-border-hairline);
  }

  .site-footer__bottom span {
    font-family: var(--font-sans);
    color: var(--color-muted);
  }

  .site-footer__logo:focus-visible,
  .site-footer__list a:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer__list a {
      transition-duration: 1ms;
    }
  }
</style>
