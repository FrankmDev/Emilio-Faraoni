---
import Container from '@/components/ui/Container.astro';
import NavLink from '@/components/layout/NavLink.astro';
import { company } from '@/data/company';
import { footerNavigation } from '@/data/navigation';
import { ROUTES } from '@/lib/routes';

/**
 * Footer · editorial spread, three columns + legal bar.
 *
 * Composition (left → right):
 *   · Brand: name, short description, address line.
 *   · Web:   the four primary navigation items.
 *   · Contact: email + phone + hours, only if confirmed.
 *
 * The contact column is rendered conditionally. When the
 * brand has not confirmed email, phone or address, the
 * column is replaced with a quiet, single-line note. We
 * never invent or placeholder contact details.
 *
 * Bottom rail: copyright, country, and a small editorial
 * tag (no public prices, no commercial urgency).
 */

interface Props {
  /** Footer presentation — 'default' (light) or 'dark'. */
  variant?: 'default' | 'dark';
}

const { variant = 'default' } = Astro.props;

const currentPath = Astro.url.pathname;
const currentYear = new Date().getFullYear();

function isActive(href: string): boolean {
  if (href === ROUTES.HOME) {
    return currentPath === ROUTES.HOME;
  }
  return currentPath === href || currentPath.startsWith(`${href}/`);
}

const hasContact = Boolean(company.email || company.phone);
const addressLine = company.location;
---

<footer
  class:list={['site-footer', variant === 'dark' && 'site-footer-dark']}
  aria-label="Pie de página"
>
  <Container wide class="site-footer__inner">
    <div class="site-footer__brand">
      <a href={ROUTES.HOME} class="site-footer__brand-name">{company.name}</a>
      <p class="site-footer__tagline">{company.shortDescription}</p>
      {addressLine && <address class="site-footer__address">{addressLine}</address>}
    </div>

    <div class="site-footer__col">
      <p class="meta-label" id="footer-web-label">Web</p>
      <ul class="site-footer__list" aria-labelledby="footer-web-label">
        {
          footerNavigation.map((item) => (
            <li>
              <NavLink href={item.href} label={item.label} active={isActive(item.href)} />
            </li>
          ))
        }
      </ul>
    </div>

    <div class="site-footer__col">
      <p class="meta-label" id="footer-contact-label">Contacto</p>
      {hasContact ? (
        <div
          class="site-footer__meta stack-sm"
          aria-labelledby="footer-contact-label"
          role="group"
        >
          {company.email && <a href={`mailto:${company.email}`}>{company.email}</a>}
          {company.phone && <a href={`tel:${company.phone.replace(/\s+/g, '')}`}>{company.phone}</a>}
        </div>
      ) : (
        <p
          class="site-footer__meta"
          aria-labelledby="footer-contact-label"
        >
          Datos de contacto disponibles bajo consulta.
        </p>
      )}
    </div>
  </Container>

  <div class="site-footer__bottom">
    <Container wide class="site-footer__bottom-inner">
      <small class="site-footer__bottom-meta">
        © {currentYear} {company.name}
      </small>
      <small class="site-footer__bottom-meta site-footer__bottom-meta--accent">
        ES · {company.country}
      </small>
      <small class="site-footer__bottom-meta">
        Editorial · sin precios públicos
      </small>
    </Container>
  </div>
</footer>
