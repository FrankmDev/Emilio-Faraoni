---
import Container from '@/components/ui/Container.astro';
---

<footer class="border-t border-border-soft bg-bg">
  <Container class="grid gap-12 py-16 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <strong class="font-serif text-2xl font-light tracking-[-0.02em] text-ink">
        Emilio Faraoni
      </strong>
      <p class="copy-small mt-4 max-w-md">
        Fabricación y distribución mayorista de cinturones, bolsos y artículos
        de marroquinería. Elche, Alicante.
      </p>
    </div>

    <nav class="grid gap-3 text-sm" aria-label="Navegación secundaria">
      <span class="meta-label">Web</span>
      <a href="/" class="text-muted transition-colors hover:text-ink">
        Inicio
      </a>
      <a href="/catalogo" class="text-muted transition-colors hover:text-ink">
        Catálogo
      </a>
      <a href="/empresa" class="text-muted transition-colors hover:text-ink">
        Empresa
      </a>
      <a href="/contacto" class="text-muted transition-colors hover:text-ink">
        Contacto
      </a>
    </nav>

    <div class="grid gap-3 text-sm text-muted">
      <span class="meta-label">Contacto</span>
      <span>Elche, Alicante</span>
      <a
        href="mailto:info@emiliofaraoni.com"
        class="transition-colors hover:text-ink"
      >
        info@emiliofaraoni.com
      </a>
      <a
        href="tel:+34965000000"
        class="transition-colors hover:text-ink"
      >
        +34 965 000 000
      </a>
    </div>
  </Container>
  <div class="border-t border-border-soft py-6">
    <Container class="text-[0.6875rem] uppercase tracking-[0.15em] text-muted">
      © {new Date().getFullYear()} Emilio Faraoni. Todos los derechos reservados.
    </Container>
  </div>
</footer>
