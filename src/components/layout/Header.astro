---
import { ROUTES } from '@/lib/routes';
---

<header class="border-b border-border-soft bg-bg/80 backdrop-blur-sm">
  <Container class="flex h-20 items-center justify-between gap-8">
    <a
      href={ROUTES.HOME}
      class="flex flex-col leading-none"
      aria-label="Emilio Faraoni inicio"
    >
      <strong class="font-serif text-2xl font-light tracking-[-0.02em] text-ink">
        Emilio Faraoni
      </strong>
      <span class="mt-1 text-[0.625rem] font-normal uppercase tracking-[0.2em] text-muted">
        Catálogo B2B
      </span>
    </a>

    <nav
      class="hidden items-center gap-8 md:flex"
      aria-label="Navegación principal"
    >
      <a
        href={ROUTES.HOME}
        class="text-[0.8125rem] font-normal tracking-[0.02em] text-muted transition-colors hover:text-ink"
      >
        Inicio
      </a>
      <a
        href={ROUTES.CATALOG}
        class="text-[0.8125rem] font-normal tracking-[0.02em] text-muted transition-colors hover:text-ink"
      >
        Catálogo
      </a>
      <a
        href={ROUTES.COMPANY}
        class="text-[0.8125rem] font-normal tracking-[0.02em] text-muted transition-colors hover:text-ink"
      >
        Empresa
      </a>
      <a
        href={ROUTES.CONTACT}
        class="text-[0.8125rem] font-normal tracking-[0.02em] text-muted transition-colors hover:text-ink"
      >
        Contacto
      </a>
    </nav>

    <a
      href={ROUTES.WHOLESALE_ACCESS}
      class="hidden border border-ink px-5 py-2 text-[0.8125rem] font-normal tracking-[0.02em] text-ink transition-colors hover:bg-ink hover:text-bg sm:inline-flex"
    >
      Acceso mayorista
    </a>
  </Container>
</header>
