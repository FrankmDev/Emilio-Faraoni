---
import Container from '@/components/ui/Container.astro';
import NavLink from '@/components/layout/NavLink.astro';
import { company } from '@/data/company';
import { mainNavigation } from '@/data/navigation';
import { ROUTES } from '@/lib/routes';

/**
 * Header · sticky editorial rail.
 *
 * Three slots: brand (left) · nav (centre, hidden on mobile)
 * · CTA (right). No boxy chrome, no commercial buttons.
 *
 * The CTA is a fine-link "Contactar" pointing at /contacto —
 * a discreet editorial handshake, never a buy / shop / cart
 * action. The CTA slot is intentionally restrained; this is
 * not a retail storefront.
 */

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === ROUTES.HOME) {
    return currentPath === ROUTES.HOME;
  }
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="site-header">
  <Container wide class="site-header__inner">
    <a
      href={ROUTES.HOME}
      class="site-header__brand"
      aria-label={`${company.name} · Inicio`}
    >
      <span>{company.name}</span>
      <span class="site-header__brand-mark" aria-hidden="true">
        {company.foundedYear}
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Navegación principal">
      {
        mainNavigation.map((item) => (
          <NavLink href={item.href} label={item.label} active={isActive(item.href)} />
        ))
      }
    </nav>

    <a href={ROUTES.CONTACT} class="site-header__cta">
      <span class="site-header__cta-dot" aria-hidden="true"></span>
      <span>Contactar</span>
      <span class="site-header__cta-arrow" aria-hidden="true">→</span>
    </a>
  </Container>
</header>
