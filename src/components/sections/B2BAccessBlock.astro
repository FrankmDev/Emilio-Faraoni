---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import { ROUTES } from '@/lib/routes';
---

<section class="section-y border-t border-border-hairline">
  <Container>
    <div
      class="surface-inverse grid gap-10 overflow-hidden p-8 md:grid-cols-[minmax(0,1fr)_minmax(18rem,0.58fr)] md:p-12"
    >
      <div>
        <p class="eyebrow text-gold-soft">Acceso mayorista</p>
        <h2 class="heading-section mt-4 max-w-2xl text-ink-on-inverse">
          Tarifas privadas para compradores profesionales
        </h2>
        <p
          class="copy-lead mt-6 max-w-2xl text-[color-mix(in_srgb,var(--color-ink-on-inverse)_76%,transparent)]"
        >
          Precios y condiciones disponibles exclusivamente para clientes
          mayoristas registrados y aprobados por la empresa.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <Button href={ROUTES.WHOLESALE_ACCESS} variant="gold">
            Solicitar acceso
          </Button>
          <Button
            href={ROUTES.CONTACT}
            variant="ghost"
            class="border-[color-mix(in_srgb,var(--color-ink-on-inverse)_32%,transparent)] text-ink-on-inverse hover:border-ink-on-inverse hover:bg-[color-mix(in_srgb,var(--color-ink-on-inverse)_10%,transparent)]"
          >
            Contactar ventas
          </Button>
        </div>
      </div>
      <div
        class="border border-[color-mix(in_srgb,var(--color-ink-on-inverse)_16%,transparent)] p-6"
      >
        <p
          class="meta-label text-[color-mix(in_srgb,var(--color-ink-on-inverse)_72%,transparent)]"
        >
          Proceso
        </p>
        <ol
          class="mt-8 grid gap-5 text-sm text-[color-mix(in_srgb,var(--color-ink-on-inverse)_76%,transparent)]"
        >
          <li>01 · Solicitud de empresa</li>
          <li>02 · Validación manual</li>
          <li>03 · Consulta de tarifas</li>
        </ol>
      </div>
    </div>
  </Container>
</section>
