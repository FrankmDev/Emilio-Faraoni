---
/**
 * FeaturedCategories · image-led category strip.
 *
 * Each category is a full-card editorial tile. Image
 * fills the tile; a soft bottom rail keeps the title
 * legible; a top rail carries an index stamp + count.
 * The first tile is marked as `featured` and spans the
 * full grid width on desktop, acting as the visual hero.
 *
 * When a category has no image, the tile falls back to
 * the temporary local workshop imagery so the grid can be
 * reviewed with real media proportions.
 */
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { categories, type Category } from '@/data/categories';
import { ROUTES } from '@/lib/routes';
import { getPublicProducts } from '@/lib/products/getters';

const allProducts = getPublicProducts();
const productCountByCategory = new Map<string, number>();
for (const product of allProducts) {
  productCountByCategory.set(
    product.categorySlug,
    (productCountByCategory.get(product.categorySlug) ?? 0) + 1,
  );
}
---

<section class="section featured-categories">
  <Container class="featured-categories__inner">
    <SectionHeader
      class="featured-categories__head"
      eyebrow="Categorías"
      description="Una estructura clara para consultar cinturones, bolsos, carteras y complementos de marroquinería sin mostrar tarifas públicas."
    >
      <span slot="title">
        <em>Líneas</em> de producto
      </span>
    </SectionHeader>

    <ul class="category-tile-grid" role="list">
      {
        categories.map((category: Category, index: number) => {
          const href = `${ROUTES.CATALOG}/${category.slug}`;
          const isFeatured = index === 0;
          const fallbackImage = isFeatured ? '/horizontal.jpg' : '/vertical.jpg';
          const image = category.image ?? fallbackImage;
          const count = productCountByCategory.get(category.slug) ?? 0;
          return (
            <li
              class:list={[isFeatured && 'category-tile-grid__cell--featured']}
            >
              <a
                class:list={[
                  'category-tile-image',
                  isFeatured && 'category-tile-image--featured',
                ]}
                href={href}
                aria-label={`Ver la línea ${category.name}`}
              >
                <div class="category-tile-image__media" aria-hidden="true">
                  <img src={image} alt="" loading="lazy" decoding="async" />
                </div>
                <span class="category-tile-image__overlay" aria-hidden="true" />
                <div class="category-tile-image__top">
                  <span class="category-tile-image__index">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <span class="category-tile-image__count">
                    {count > 0
                      ? `${String(count).padStart(2, '0')} referencias`
                      : 'Próximamente'}
                  </span>
                </div>
                <div class="category-tile-image__body">
                  <p class="category-tile-image__eyebrow">Línea</p>
                  <h3 class="category-tile-image__title">{category.name}</h3>
                  {isFeatured && category.description && (
                    <p class="category-tile-image__desc">
                      {category.description}
                    </p>
                  )}
                  <span class="category-tile-image__cta" aria-hidden="true">
                    Explorar línea
                  </span>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </Container>
</section>
