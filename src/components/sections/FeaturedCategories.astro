---
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { categories } from '@/data/categories';
---

<section class="section-y-compact">
  <Container class="grid gap-12">
    <SectionHeader
      eyebrow="Categorías"
      title="Líneas de producto"
      description="Datos locales mínimos para validar estructura."
    />
    <div class="grid gap-px bg-border-soft sm:grid-cols-2 lg:grid-cols-4">
      {
        categories.map((category) => (
          <article class="bg-bg p-8">
            <h3 class="font-serif text-2xl font-light tracking-[-0.01em] text-ink">
              {category.name}
            </h3>
            <p class="copy-small mt-3">{category.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
