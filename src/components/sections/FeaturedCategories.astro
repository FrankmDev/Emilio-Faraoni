---
import { categories } from '@/data/categories';
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
---

<section class="py-14">
  <Container class="grid gap-8">
    <SectionHeader
      title="Categorías iniciales"
      description="Datos locales mínimos para validar estructura."
    />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        categories.map((category) => (
          <article class="rounded-sm border border-border bg-surface p-5">
            <h3 class="font-semibold text-ink">{category.name}</h3>
            <p class="mt-2 text-sm leading-6 text-muted">
              {category.description}
            </p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
