---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import { ROUTES } from '@/lib/routes';
---

<section class="section-y">
  <Container>
    <p class="eyebrow">Siguiente paso</p>
    <h2 class="heading-section mt-4 max-w-2xl text-ink">
      Base preparada para la siguiente tarea
    </h2>
    <p class="copy-lead mt-6 max-w-2xl">
      El siguiente paso puede ser crear rutas de catálogo y fichas de
      producto sobre esta estructura.
    </p>
    <div class="mt-10 flex flex-wrap gap-3">
      <Button href={ROUTES.CONTACT} variant="secondary">
        Contacto comercial
      </Button>
    </div>
  </Container>
</section>
