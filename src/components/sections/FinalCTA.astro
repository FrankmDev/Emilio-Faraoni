---
import { ROUTES } from '@/lib/routes';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
---

<section class="py-16">
  <Container class="rounded-sm border border-border bg-surface p-8">
    <h2 class="text-3xl font-semibold leading-tight text-ink">
      Base preparada para la siguiente tarea
    </h2>
    <p class="mt-3 max-w-2xl text-muted">
      El siguiente paso puede ser crear rutas de catálogo y fichas de producto
      sobre esta estructura.
    </p>
    <div class="mt-6">
      <Button href={ROUTES.CONTACT} variant="secondary"
        >Contacto comercial</Button
      >
    </div>
  </Container>
</section>
