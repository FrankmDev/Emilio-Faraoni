---
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import ProductGrid from '@/components/product/ProductGrid.astro';
import { getPublicFeaturedProducts } from '@/lib/products/getters';

const products = getPublicFeaturedProducts();
---

<section class="section-y-compact border-t border-border-hairline">
  <Container class="grid gap-12">
    <SectionHeader
      eyebrow="Productos destacados"
      title="Selección de catálogo"
      description="Referencias iniciales para validar presentación de producto, navegación y consulta pública sin exponer tarifas mayoristas."
    />
    <ProductGrid products={products} />
  </Container>
</section>
