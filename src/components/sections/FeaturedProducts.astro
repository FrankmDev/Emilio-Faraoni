---
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import ProductGrid from '@/components/product/ProductGrid.astro';
import { getPublicFeaturedProducts } from '@/lib/products/getters';

const products = getPublicFeaturedProducts();
---

<section class="section-y-compact">
  <Container class="grid gap-12">
    <SectionHeader
      eyebrow="Productos destacados"
      title="Selección de catálogo"
      description="Solo referencias de prueba. No se renderizan precios."
    />
    <ProductGrid products={products} />
  </Container>
</section>
