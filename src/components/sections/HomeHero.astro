---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import { ROUTES } from '@/lib/routes';
---

<section class="section-y">
  <Container class="grid gap-10">
    <p class="eyebrow">
      Catálogo mayorista
    </p>
    <div class="max-w-4xl">
      <h1 class="display-serif text-ink">
        Base técnica para Emilio Faraoni B2B
      </h1>
      <p class="copy-lead mt-8 max-w-2xl">
        Proyecto Astro preparado para crecer hacia catálogo profesional,
        acceso mayorista y precios privados.
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <Button href={ROUTES.CATALOG}>Ver estructura de catálogo</Button>
      <Button href={ROUTES.WHOLESALE_ACCESS} variant="secondary">
        Acceso mayorista
      </Button>
    </div>
  </Container>
</section>
