---
/**
 * PageHero · editorial opener for internal pages.
 *
 * Five composition shapes (set via `variant`):
 * - default  : type-only, left aligned, atelier frame.
 * - centered : type-only, centred, atelier frame.
 * - compact  : type-only, tighter vertical rhythm.
 * - split    : type on one side, image on the other.
 * - media    : type layered over a full-bleed image.
 *
 * The hero follows the same editorial language as FinalCTA:
 *   - top atelier strip  (index · location / dot · tag)
 *   - corner brackets    (hairline L with leather studs)
 *   - background numeral (giant faded editorial watermark)
 *   - hairline rule      (with leather dot above the actions)
 *   - bottom signature   (EF · rule · note · year)
 *
 * For the `media` variant the hero spans 100% of the viewport
 * and renders the image as a full-bleed background; the atelier
 * framing rides on top in the inverse palette, the corner
 * brackets hide so the photograph keeps the frame, and the
 * existing frame marks + side rail + provenance are preserved.
 *
 * All visual tokens live in `src/styles/global.css` under
 * `.page-hero*` so this file stays structural.
 */
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';

type PageHeroVariant = 'default' | 'centered' | 'compact' | 'split' | 'media';
type PageHeroTone = 'dark' | 'light';
type PageHeroAlign = 'left' | 'center';

interface CtaSpec {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'inverse' | 'gold';
}

interface Props {
  variant?: PageHeroVariant;
  align?: PageHeroAlign;
  tone?: PageHeroTone;
  reverse?: boolean;
  eyebrow?: string;
  kicker?: string;
  index?: string;
  meta?: string;
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageFocus?: string;
  caption?: string;
  sideRail?: string;
  provenance?: string;
  primaryCta?: CtaSpec;
  secondaryCta?: CtaSpec;
  /** Atelier tag in the top-right strip, e.g. "Empresa · 1988". */
  tag?: string;
  /** Footer signature line, e.g. "Fabricación artesanal · Elche". */
  note?: string;
  class?: string;
}

const {
  variant = 'default',
  align = 'left',
  tone = 'dark',
  reverse = false,
  eyebrow,
  kicker,
  index,
  meta,
  title,
  description,
  image,
  imageAlt,
  imageFocus,
  caption,
  sideRail,
  provenance,
  primaryCta,
  secondaryCta,
  tag = 'Empresa · 1988',
  note = 'Fabricación artesanal · Elche',
  class: className,
} = Astro.props;

const isMedia = variant === 'media';
const isSplit = variant === 'split';

const sectionClass = [
  'page-hero',
  `page-hero--${variant}`,
  align === 'center' && 'page-hero--centered',
  reverse && 'page-hero--reverse',
  isMedia && `page-hero--tone-${tone}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const mediaStyle = imageFocus ? `object-position: ${imageFocus};` : undefined;

const titleClass = ['page-hero__title', align === 'center' && 'text-center']
  .filter(Boolean)
  .join(' ');

const railClass = ['page-hero__top', align === 'center' && 'justify-center']
  .filter(Boolean)
  .join(' ');

const bodyClass = [
  'page-hero__body',
  align === 'center' && 'page-hero__body--center',
]
  .filter(Boolean)
  .join(' ');

const actionsClass = [
  'page-hero__actions',
  align === 'center' && 'justify-center',
]
  .filter(Boolean)
  .join(' ');

const showTopRail = Boolean(eyebrow || kicker || index || meta);
const showActions = Boolean(primaryCta || secondaryCta);
/* The corner brackets hide on the media variant — the
   photograph is the frame. The atelier strip and signature
   stay (in the inverse palette) so the hero keeps its
   editorial register even over a photo. */
const showCorners = !isMedia;
const showStrip = true;
const showSignature = true;
const showSideRail = isMedia && Boolean(sideRail);
const showProvenance = isMedia && Boolean(provenance);

/* Media variant automatically inverts the buttons so they
   read against the dark photo. */
const defaultPrimaryVariant = isMedia ? 'inverse' : 'primary';
const defaultSecondaryVariant = isMedia ? 'inverse' : 'secondary';

/* The numeral stamp is the `index` prop when present, falling
   back to a Roman "I" so the watermark always renders. */
const numeralText = index ?? 'I';

/* Accessibility: when an image is provided to the `media`
   variant and a meaningful alt is supplied, mark the section
   as a labelled image. Otherwise the image is decorative and
   the text content is what gets announced. */
const ariaRole = isMedia && imageAlt ? 'img' : undefined;
const ariaLabel = isMedia && imageAlt ? imageAlt : undefined;
---

<section class={sectionClass} role={ariaRole} aria-label={ariaLabel}>
  {
    isMedia && image && (
      <img
        src={image}
        alt=""
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="page-hero__media-bg"
        style={mediaStyle}
        aria-hidden="true"
      />
    )
  }

  <span class="page-hero__numeral" aria-hidden="true">{numeralText}</span>

  {
    showCorners && (
      <div class="page-hero__frame" aria-hidden="true">
        <span class="page-hero__corner page-hero__corner--tl"></span>
        <span class="page-hero__corner page-hero__corner--tr"></span>
        <span class="page-hero__corner page-hero__corner--bl"></span>
        <span class="page-hero__corner page-hero__corner--br"></span>
      </div>
    )
  }

  {
    showStrip && (
      <header class="page-hero__strip">
        <span class="page-hero__strip-left">
          {index && (
            <>
              <span class="page-hero__strip-index">Nº&nbsp;{index}</span>
              <span class="page-hero__strip-sep" aria-hidden="true" />
            </>
          )}
          <span class="page-hero__strip-location">Elche · Alicante</span>
        </span>
        <span class="page-hero__strip-right">
          <span class="page-hero__strip-dot" aria-hidden="true" />
          <span class="page-hero__strip-tag">{tag}</span>
        </span>
      </header>
    )
  }

  {
    showSideRail && (
      <span class="page-hero__side-rail" aria-hidden="true">
        {sideRail}
      </span>
    )
  }

  <Container>
    <div class="page-hero-inner">
      {
        isSplit ? (
          <div class="page-hero__grid">
            <div class={bodyClass}>
              {showTopRail && (
                <div class={railClass}>
                  {eyebrow && (
                    <p class="eyebrow page-hero__eyebrow">{eyebrow}</p>
                  )}
                  {kicker && (
                    <p class="meta-label page-hero__kicker">{kicker}</p>
                  )}
                  {meta && <p class="meta-label page-hero__meta">{meta}</p>}
                </div>
              )}
              <h1 class={titleClass} set:html={title} />
              {description && <p class="page-hero__description">{description}</p>}
              {showActions && (
                <>
                  <hr class="page-hero__rule" aria-hidden="true" />
                  <div class={actionsClass}>
                    {primaryCta && (
                      <Button
                        href={primaryCta.href}
                        variant={primaryCta.variant ?? defaultPrimaryVariant}
                      >
                        {primaryCta.label}
                      </Button>
                    )}
                    {secondaryCta && (
                      <Button
                        href={secondaryCta.href}
                        variant={secondaryCta.variant ?? defaultSecondaryVariant}
                      >
                        {secondaryCta.label}
                      </Button>
                    )}
                  </div>
                </>
              )}
            </div>

            {image && (
              <figure class="page-hero__media">
                <img
                  src={image}
                  alt={imageAlt ?? ''}
                  loading="eager"
                  decoding="async"
                  style={mediaStyle}
                />
                {caption && (
                  <figcaption class="page-hero__caption meta-label">
                    {caption}
                  </figcaption>
                )}
              </figure>
            )}
          </div>
        ) : (
          <div class={bodyClass}>
            {showTopRail && (
              <div class={railClass}>
                {eyebrow && (
                  <p class="eyebrow page-hero__eyebrow">{eyebrow}</p>
                )}
                {kicker && (
                  <p class="meta-label page-hero__kicker">{kicker}</p>
                )}
                {meta && <p class="meta-label page-hero__meta">{meta}</p>}
              </div>
            )}
            <h1 class={titleClass} set:html={title} />
            {description && <p class="page-hero__description">{description}</p>}
            {showActions && (
              <>
                <hr class="page-hero__rule" aria-hidden="true" />
                <div class={actionsClass}>
                  {primaryCta && (
                    <Button
                      href={primaryCta.href}
                      variant={primaryCta.variant ?? defaultPrimaryVariant}
                    >
                      {primaryCta.label}
                    </Button>
                  )}
                  {secondaryCta && (
                    <Button
                      href={secondaryCta.href}
                      variant={secondaryCta.variant ?? defaultSecondaryVariant}
                    >
                      {secondaryCta.label}
                    </Button>
                  )}
                </div>
              </>
            )}
          </div>
        )
      }

      {
        showProvenance && (
          <div class="page-hero__provenance">
            <p class="page-hero__provenance-text meta-label">{provenance}</p>
          </div>
        )
      }
    </div>
  </Container>

  {
    showSignature && (
      <footer class="page-hero__signature">
        <span class="page-hero__signature-mark">EF</span>
        <span class="page-hero__signature-rule" aria-hidden="true" />
        <span class="page-hero__signature-note">{note}</span>
        <span
          class="page-hero__signature-rule page-hero__signature-rule--end"
          aria-hidden="true"
        />
        <span class="page-hero__signature-year">1988</span>
      </footer>
    )
  }
</section>
