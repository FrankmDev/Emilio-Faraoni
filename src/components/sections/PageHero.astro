---
/**
 * PageHero · editorial opener for internal pages.
 *
 * Five composition shapes (set via `variant`):
 * - default : type-only, left aligned, hairline top.
 * - centered: type-only, centred.
 * - compact : type-only, tighter vertical rhythm.
 * - split   : type on one side, image on the other.
 * - media   : type layered over a full-bleed image.
 *
 * When `image` is provided, the consumer should also set
 * `imageAlt` (required). Optional `tone` controls the
 * overlay opacity (light = paper-coloured wash, dark =
 * ink-coloured wash — default dark).
 *
 * All visual tokens live in src/styles/global.css under
 * `.page-hero*` so this file stays structural.
 */
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';

type PageHeroVariant = 'default' | 'centered' | 'compact' | 'split' | 'media';
type PageHeroTone = 'dark' | 'light';
type PageHeroAlign = 'left' | 'center';

interface CtaSpec {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'inverse' | 'gold';
}

interface Props {
  variant?: PageHeroVariant;
  align?: PageHeroAlign;
  tone?: PageHeroTone;
  reverse?: boolean;
  eyebrow?: string;
  kicker?: string;
  index?: string;
  meta?: string;
  title: string;
  description?: string;
  /** Optional image URL. Required for split and media variants. */
  image?: string;
  imageAlt?: string;
  /** Optional CSS object-position keyword. */
  imageFocus?: string;
  /** Optional caption rendered on the media (split variant). */
  caption?: string;
  primaryCta?: CtaSpec;
  secondaryCta?: CtaSpec;
  class?: string;
}

const {
  variant = 'default',
  align = 'left',
  tone = 'dark',
  reverse = false,
  eyebrow,
  kicker,
  index,
  meta,
  title,
  description,
  image,
  imageAlt,
  imageFocus,
  caption,
  primaryCta,
  secondaryCta,
  class: className,
} = Astro.props;

const hasImage = Boolean(image);
const isMedia = variant === 'media';
const isSplit = variant === 'split';

const sectionClass = [
  'page-hero',
  `page-hero--${variant}`,
  align === 'center' && 'page-hero--centered',
  reverse && 'page-hero--reverse',
  isMedia && `page-hero--tone-${tone}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const bleedStyle =
  isMedia && image ? `--page-hero-image: url('${image}');` : undefined;
const mediaStyle = imageFocus ? `object-position: ${imageFocus};` : undefined;

const titleClass = ['page-hero__title', align === 'center' && 'text-center']
  .filter(Boolean)
  .join(' ');

const railClass = ['page-hero__top', align === 'center' && 'justify-center']
  .filter(Boolean)
  .join(' ');

const bodyClass = [
  'page-hero__body',
  align === 'center' && 'page-hero__body--center',
]
  .filter(Boolean)
  .join(' ');

const showTopRail = Boolean(eyebrow || kicker || index || meta);
const showActions = Boolean(primaryCta || secondaryCta);

const actionsClass = [
  'page-hero__actions',
  align === 'center' && 'justify-center',
]
  .filter(Boolean)
  .join(' ');
---

<section class={sectionClass} style={bleedStyle}>
  <Container>
    <div class="page-hero__inner-wrap">
      {
        isSplit ? (
          <div class="page-hero__grid">
            <div class={bodyClass}>
              {showTopRail && (
                <div class={railClass}>
                  {index && (
                    <span class="page-hero__index" aria-hidden="true">
                      {index}
                    </span>
                  )}
                  {eyebrow && (
                    <p class="eyebrow page-hero__eyebrow">{eyebrow}</p>
                  )}
                  {kicker && (
                    <p class="meta-label page-hero__kicker">{kicker}</p>
                  )}
                  {meta && <p class="meta-label page-hero__meta">{meta}</p>}
                </div>
              )}
              <h1 class={titleClass} set:html={title} />
              {description && (
                <p class="page-hero__description">{description}</p>
              )}
              {showActions && (
                <div class={actionsClass}>
                  {primaryCta && (
                    <Button
                      href={primaryCta.href}
                      variant={primaryCta.variant ?? 'primary'}
                    >
                      {primaryCta.label}
                    </Button>
                  )}
                  {secondaryCta && (
                    <Button
                      href={secondaryCta.href}
                      variant={secondaryCta.variant ?? 'secondary'}
                    >
                      {secondaryCta.label}
                    </Button>
                  )}
                </div>
              )}
            </div>

            {image && (
              <figure class="page-hero__media">
                <img
                  src={image}
                  alt={imageAlt ?? ''}
                  loading="eager"
                  decoding="async"
                  style={mediaStyle}
                />
                {caption && (
                  <figcaption class="page-hero__caption meta-label">
                    {caption}
                  </figcaption>
                )}
              </figure>
            )}
          </div>
        ) : (
          <div class={bodyClass}>
            {showTopRail && (
              <div class={railClass}>
                {index && (
                  <span class="page-hero__index" aria-hidden="true">
                    {index}
                  </span>
                )}
                {eyebrow && <p class="eyebrow page-hero__eyebrow">{eyebrow}</p>}
                {kicker && <p class="meta-label page-hero__kicker">{kicker}</p>}
                {meta && <p class="meta-label page-hero__meta">{meta}</p>}
              </div>
            )}
            <h1 class={titleClass} set:html={title} />
            {description && <p class="page-hero__description">{description}</p>}
            {showActions && (
              <div class={actionsClass}>
                {primaryCta && (
                  <Button
                    href={primaryCta.href}
                    variant={primaryCta.variant ?? 'primary'}
                  >
                    {primaryCta.label}
                  </Button>
                )}
                {secondaryCta && (
                  <Button
                    href={secondaryCta.href}
                    variant={secondaryCta.variant ?? 'secondary'}
                  >
                    {secondaryCta.label}
                  </Button>
                )}
              </div>
            )}
          </div>
        )
      }
    </div>
  </Container>
</section>
