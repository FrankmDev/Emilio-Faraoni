---
import Container from '@/components/ui/Container.astro';
---

<section class="section-y-compact">
  <Container>
    <p class="eyebrow">Desde 1976</p>
    <h2 class="heading-section mt-4 max-w-2xl text-ink">
      Fabricante mayorista en Elche
    </h2>
    <p class="copy-lead mt-6 max-w-2xl">
      Más de cuatro décadas de experiencia en la fabricación y distribución
      de artículos de marroquinería para clientes profesionales.
    </p>
  </Container>
</section>
