---
/**
 * CompanyIntro · editorial company block.
 *
 * Two-column composition: the atelier year panel (the 1988
 * brand mark) on the left, narrative + differentiators on
 * the right. The image is optional; when present, it
 * replaces the year panel as the visual anchor. A `reverse`
 * modifier flips the column order.
 *
 * The rail, title, lead and body stack reuse the global
 * `.cluster`, `.heading-section`, `.copy-lead` and
 * `.stack-md` tokens. The differentiators list reuses
 * `.differentiator-list`. The atelier year panel and the
 * top rail are owned by the global `.company-intro*` block.
 */
import Container from '@/components/ui/Container.astro';
import { ROUTES } from '@/lib/routes';

interface Differentiator {
  title: string;
  detail: string;
}

interface Props {
  /** Section / chapter index rendered in the top rail. */
  index?: string;
  /** Small kicker shown in the top rail. */
  railLabel?: string;
  /** Location mark shown in the top rail and the year panel. */
  location?: string;
  /** Eyebrow above the heading. */
  eyebrow?: string;
  /** Section heading. */
  title?: string;
  /** Lead paragraph supporting the heading. */
  description?: string;
  /** Differentiator items. */
  differentiators?: Differentiator[];
  /** Optional CTA path for the fine-link. */
  ctaHref?: string;
  /** Optional CTA label. */
  ctaLabel?: string;
  /** Optional media (workshop photo). When provided the year
   *  panel is replaced by the image. */
  image?: string;
  imageAlt?: string;
  /** Reverse the column order (image/panel on the right). */
  reverse?: boolean;
  /** Section id (for skip-links / deep linking). */
  id?: string;
  class?: string;
}

const defaultDifferentiators: Differentiator[] = [
  {
    title: 'Empresa familiar',
    detail:
      'Trayectoria familiar dedicada a la marroquinería en Elche desde 1988, con continuidad de oficio y relación profesional.',
  },
  {
    title: 'Fabricación artesanal',
    detail:
      'Control del proceso, selección de materiales y cuidado del acabado en artículos de cuero para cliente profesional.',
  },
  {
    title: 'Producto y materiales nacionales',
    detail:
      'Fabricación nacional y materiales nacionales como base de una propuesta sobria, consistente y preparada para crecer.',
  },
  {
    title: 'Relación B2B profesional',
    detail:
      'Atención comercial directa para tiendas, distribuidores y compradores especializados.',
  },
];

const {
  index = '01',
  railLabel = 'Capítulo',
  location = 'Elche · Alicante',
  eyebrow = 'Empresa familiar',
  title = 'Fabricación nacional de marroquinería desde 1988',
  description = 'Emilio Faraoni es una empresa familiar de Elche, Alicante, dedicada al desarrollo y fabricación de artículos de cuero para clientes profesionales. Cinturones, bolsos y complementos de piel, elaborados con criterio de oficio y producción nacional.',
  differentiators = defaultDifferentiators,
  ctaHref = ROUTES.COMPANY,
  ctaLabel = 'Conocer la empresa',
  image,
  imageAlt,
  reverse = false,
  id = 'empresa',
  class: className,
} = Astro.props;

const sectionClass = [
  'company-intro',
  reverse && 'company-intro--reverse',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<section class={sectionClass} aria-labelledby={`${id}-title`}>
  <Container>
    <header class="company-intro__rail cluster-between">
      <p class="cluster company-intro__rail-tag">
        <span
          class="editorial-numeral company-intro__rail-index"
          aria-hidden="true"
        >
          {index}
        </span>
        <span class="meta-label">{railLabel} · La empresa</span>
      </p>
      <p
        class="cluster meta-label company-intro__rail-location"
        aria-label="Ubicación"
      >
        <span class="company-intro__rail-dot" aria-hidden="true"></span>
        {location}
      </p>
    </header>

    <div class="company-intro__grid">
      {
        image ? (
          <figure
            class="company-intro__media"
            aria-label={imageAlt ?? 'Imagen de taller o proceso'}
          >
            <img
              src={image}
              alt={imageAlt ?? ''}
              loading="lazy"
              decoding="async"
            />
          </figure>
        ) : (
          <aside class="company-intro__atelier" aria-label="Fundada en 1988">
            <span class="company-intro__atelier-corner" aria-hidden="true" />
            <div class="company-intro__atelier-top">
              <span class="meta-label">Fundada en</span>
              <span class="company-intro__stamp" aria-hidden="true">
                F · 1988
              </span>
            </div>
            <p
              class="company-intro__atelier-year editorial-year"
              aria-hidden="true"
            >
              1988
            </p>
            <div class="company-intro__atelier-foot">
              <span class="meta-label">{location}</span>
              <span class="meta-label" aria-hidden="true">
                Tres décadas
              </span>
            </div>
          </aside>
        )
      }

      <div class="company-intro__body stack-md">
        <p class="eyebrow">{eyebrow}</p>
        <h2 id={`${id}-title`} class="heading-section">
          {title}
        </h2>
        <p class="copy-lead">{description}</p>

        <dl class="differentiator-list" aria-label="Diferenciales de empresa">
          {
            differentiators.map((item, i) => (
              <div class="differentiator-item">
                <dt class="differentiator-item__title">
                  <span class="differentiator-item__index" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span>{item.title}</span>
                </dt>
                <dd class="differentiator-item__detail">{item.detail}</dd>
              </div>
            ))
          }
        </dl>

        {
          ctaHref && ctaLabel && (
            <p class="company-intro__cta">
              <a href={ctaHref} class="fine-link company-intro__link">
                {ctaLabel}
              </a>
            </p>
          )
        }
      </div>
    </div>
  </Container>
</section>
