---
/**
 * ArticleHeader · editorial article opener.
 * Two-column composition: copy on the left (eyebrow, title,
 * excerpt, byline, index numeral), cover on the right (image
 * with a hairline frame and corner stamp). When no `image`
 * is provided the cover falls back to a tonal placeholder
 * so the layout never collapses.
 *
 * Pass an `author` to render the byline strip (author · date
 * · reading time) below the excerpt.
 */
import Container from '@/components/ui/Container.astro';

type BaseProps = {
  eyebrow?: string;
  category?: string;
  title: string;
  excerpt?: string;
  date?: string;
  readingTime?: string;
  /** Author of the article. When provided, a byline strip
   *  is rendered. */
  author?: string;
  /** Editorial signature, e.g. "N° 01" or "01 / 06". */
  index?: string;
  /** Cover caption rendered as a small label in the lower-left. */
  caption?: string;
  /** Visual order — 'cover-right' (default) or 'cover-left'. */
  align?: 'cover-right' | 'cover-left';
  class?: string;
};

type CoverProps =
  | {
      /** Optional cover image URL. */
      image: string;
      /** Cover image alt text. Required when `image` is provided. */
      imageAlt: string;
    }
  | {
      image?: undefined;
      imageAlt?: never;
    };

type Props = BaseProps & CoverProps;

const {
  eyebrow,
  category,
  title,
  excerpt,
  date,
  readingTime,
  author,
  index = 'N° 01',
  image,
  imageAlt,
  caption,
  align = 'cover-right',
  class: className,
} = Astro.props;

const hasMeta = Boolean(category || date || readingTime || author);
const hasByline = Boolean(author || date || readingTime);

const sectionClass = [
  'article-header',
  align === 'cover-left' && 'article-header--reverse',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<section class={sectionClass}>
  <Container class="article-header__inner">
    <div class="article-header__body">
      {eyebrow && <p class="article-header__eyebrow">{eyebrow}</p>}

      <h1 class="article-header__title">
        <Fragment set:html={title} />
      </h1>

      {excerpt && <p class="article-header__excerpt copy-lead">{excerpt}</p>}

      {
        hasByline && (
          <ul class="fine-meta article-header__byline" aria-label="Byline">
            {author && <li class="article-header__byline__author">{author}</li>}
            {date && <li>{date}</li>}
            {readingTime && <li>{readingTime}</li>}
          </ul>
        )
      }

      {
        hasMeta && !hasByline && (
          <dl class="article-header__meta">
            {category && (
              <div class="article-header__meta-row">
                <dt>Sección</dt>
                <dd>{category}</dd>
              </div>
            )}
            {date && (
              <div class="article-header__meta-row">
                <dt>Fecha</dt>
                <dd>{date}</dd>
              </div>
            )}
            {readingTime && (
              <div class="article-header__meta-row">
                <dt>Lectura</dt>
                <dd>{readingTime}</dd>
              </div>
            )}
          </dl>
        )
      }

      <p class="article-header__index" aria-hidden="true">{index}</p>
    </div>

    <figure
      class:list={[
        'article-header__cover',
        !image && 'article-header__cover--placeholder',
      ]}
      aria-hidden={image ? undefined : 'true'}
    >
      {
        image && (
          <img
            src={image}
            alt={imageAlt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="article-header__cover-image"
          />
        )
      }
      <span
        class="article-header__cover-stamp article-header__cover-stamp--tl"
        aria-hidden="true"></span>
      <span
        class="article-header__cover-stamp article-header__cover-stamp--br"
        aria-hidden="true"></span>
      {
        caption && image && (
          <span class="article-header__cover-caption meta-label">
            {caption}
          </span>
        )
      }
    </figure>
  </Container>
</section>
