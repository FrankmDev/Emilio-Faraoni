---
export type BreadcrumbItem = {
  label: string;
  href?: string;
};

type Separator = 'chevron' | 'slash' | 'dot' | 'rule' | 'diamond';

interface Props {
  items: BreadcrumbItem[];
  context?: string;
  /** Maximum visible items on mobile. Intermediate items are
   *  collapsed to an ellipsis that links to the parent. */
  maxMobile?: number;
  /** Separator between items. Defaults to 'slash'. */
  separator?: Separator;
  /** Show a leading home icon. */
  home?: boolean;
  /** Trailing meta strip (rendered as a meta-label). */
  meta?: string;
  /** Visual emphasis. 'bare' (default) is clean inline.
   *  'pill' wraps the trail in a soft pill surface. */
  variant?: 'bare' | 'pill';
  class?: string;
}

const {
  items,
  context,
  maxMobile = 3,
  separator = 'slash',
  home = false,
  meta,
  variant = 'bare',
  class: className,
} = Astro.props;

// On mobile, keep first + last + ellipsis when the trail is long.
const lastIndex = items.length - 1;
const isLongTrail = items.length > maxMobile;
const collapseParent =
  isLongTrail && lastIndex >= 1 ? items[lastIndex - 1] : undefined;
const firstItem = items[0];
const lastItem = items[lastIndex];

const visibleItems: Array<{
  label: string;
  href?: string;
  isEllipsis?: boolean;
}> = isLongTrail
  ? [firstItem, { label: '…' }, lastItem].filter(
      (item): item is { label: string; href?: string } => item !== undefined,
    )
  : items;

const homeHref = items[0]?.href ?? '/';
const classes = [
  'breadcrumb',
  `breadcrumb--sep-${separator}`,
  `breadcrumb--${variant}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<nav aria-label="Migas de pan" class={classes}>
  <div class="breadcrumb__inner">
    {context && <span class="breadcrumb__context meta-label">{context}</span>}
    <ol class="breadcrumb__list">
      {
        home && (
          <li class="breadcrumb__item breadcrumb__item--home">
            <a href={homeHref} class="breadcrumb__home" aria-label="Inicio">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M2 6.5L7 2l5 4.5" />
                <path d="M3 6v5.5h8V6" />
              </svg>
            </a>
          </li>
        )
      }
      {
        visibleItems.map((item, index) => (
          <li class="breadcrumb__item">
            {index > 0 && (
              <span aria-hidden="true" class="breadcrumb__sep">
                {separator === 'chevron' && (
                  <svg
                    width="6"
                    height="10"
                    viewBox="0 0 6 10"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    class="breadcrumb__sep-mark"
                    aria-hidden="true"
                  >
                    <path d="M1 1l4 4-4 4" />
                  </svg>
                )}
                {separator === 'slash' && (
                  <span class="breadcrumb__sep-mark breadcrumb__sep-mark--slash">
                    /
                  </span>
                )}
                {separator === 'dot' && (
                  <span class="breadcrumb__sep-mark breadcrumb__sep-mark--dot" />
                )}
                {separator === 'rule' && (
                  <span class="breadcrumb__sep-mark breadcrumb__sep-mark--rule" />
                )}
                {separator === 'diamond' && (
                  <span class="breadcrumb__sep-mark breadcrumb__sep-mark--diamond" />
                )}
              </span>
            )}
            {item.label === '…' && collapseParent?.href ? (
              <a
                href={collapseParent.href}
                class="breadcrumb__ellipsis"
                aria-label={`Saltar a ${collapseParent.label ?? ''}`}
              >
                …
              </a>
            ) : item.href ? (
              <a href={item.href} class="breadcrumb__link">
                {item.label}
              </a>
            ) : (
              <span aria-current="page" class="breadcrumb__current">
                {item.label}
              </span>
            )}
          </li>
        ))
      }
    </ol>
    {
      meta && (
        <span class="breadcrumb__meta meta-label" aria-hidden="true">
          {meta}
        </span>
      )
    }
  </div>
</nav>

<style>
  /* =========================================================
     Breadcrumb · thin editorial path.
     Built on the global .breadcrumb token. This layer adds
     the home icon, separators and hover treatments.
     ========================================================= */
  .breadcrumb {
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 650;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .breadcrumb--pill {
    display: inline-flex;
  }

  .breadcrumb--pill .breadcrumb__inner {
    padding: 0.5rem 0.65rem 0.5rem 0.9rem;
    border-radius: var(--radius-pill);
    background: var(--color-surface-soft);
  }

  .breadcrumb--bare .breadcrumb__inner {
    padding: 0;
  }

  .breadcrumb__inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem 0.55rem;
  }

  /* Optional context label — sits to the left of the trail. */
  .breadcrumb__context {
    color: var(--color-ink);
    padding-right: 0.65rem;
    margin-right: 0.1rem;
    border-right: 1px solid var(--color-border);
  }

  .breadcrumb__meta {
    margin-left: auto;
    color: var(--color-muted);
    padding-left: 0.65rem;
  }

  .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  .breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-width: 0;
  }

  /* =========================================================
     Home icon — clean monoline, quiet circular hover.
     ========================================================= */
  .breadcrumb__home {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-soft);
  }

  .breadcrumb__home:hover,
  .breadcrumb__home:focus-visible {
    color: var(--color-ink);
  }

  .breadcrumb__home:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 3px;
  }

  /* =========================================================
     Separators — small, discreet. Three options:
     chevron, slash, dot.
     ========================================================= */
  .breadcrumb__sep {
    display: inline-flex;
    align-items: center;
    color: var(--color-muted-light);
    line-height: 1;
    user-select: none;
  }

  .breadcrumb__sep-mark {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
  }

  .breadcrumb--sep-chevron .breadcrumb__sep-mark {
    width: 5px;
    height: 8px;
  }

  .breadcrumb__sep-mark--slash {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--color-muted-light);
    transform: translateY(-1px);
  }

  .breadcrumb__sep-mark--dot {
    width: 3px;
    height: 3px;
    border-radius: var(--radius-pill);
    background: currentColor;
    opacity: 0.55;
  }

  /* =========================================================
     Link — clean colour shift on hover. No pill, no lift.
     ========================================================= */
  .breadcrumb__link {
    color: var(--color-muted);
    text-decoration: none;
    max-width: 28ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color var(--duration-base) var(--ease-soft);
  }

  .breadcrumb__link:hover,
  .breadcrumb__link:focus-visible {
    color: var(--color-ink);
  }

  .breadcrumb__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 3px;
  }

  /* =========================================================
     Ellipsis — collapsed intermediate item.
     ========================================================= */
  .breadcrumb__ellipsis {
    color: var(--color-muted);
    text-decoration: none;
    line-height: 1;
    transition: color var(--duration-base) var(--ease-soft);
  }

  .breadcrumb__ellipsis:hover,
  .breadcrumb__ellipsis:focus-visible {
    color: var(--color-ink);
  }

  .breadcrumb__ellipsis:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 3px;
  }

  /* =========================================================
     Current page — same uppercase, slightly stronger weight
     and ink colour.
     ========================================================= */
  .breadcrumb__current {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-weight: 700;
    line-height: 1;
    max-width: 32ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Mobile — the trail stays the same size; the wrapper
     just wraps more aggressively. The context label and
     the trailing meta are hidden on small viewports to
     keep the trail readable. */
  @media (max-width: 640px) {
    .breadcrumb__link,
    .breadcrumb__current {
      max-width: 18ch;
    }

    .breadcrumb__context {
      display: none;
    }

    .breadcrumb__meta {
      display: none;
    }
  }

  /* Reduced motion — already covered by the global rule, but
     the home icon and links should also avoid any future
     transition additions. */
  @media (prefers-reduced-motion: reduce) {
    .breadcrumb__home,
    .breadcrumb__link,
    .breadcrumb__current,
    .breadcrumb__ellipsis {
      transition: none;
    }
  }
</style>
