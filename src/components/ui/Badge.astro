---
/**
 * Badge · modern editorial chip.
 *
 * Generous-radius chips for product tags, category markers,
 * status pills and featured callouts. Designed to feel
 * crafted-but-lively — Zara, Mango, Pull&Bear, Sfera level of
 * refinement. Less old-world stamp, more ecom presence.
 *
 * - Generous pill (default) / rounded / square shapes
 * - Soft warm surface with hairline border
 * - Modern lift + color shift + warm shadow on hover
 * - Filled circular dot (scales on hover)
 * - Subtle backdrop blur for absolute-positioned chips
 *   over media
 *
 * API is kept for backwards compatibility. `variant` and the
 * `sand` tone are still supported.
 */
type BadgeTone =
  | 'neutral'
  | 'ink'
  | 'leather'
  | 'outline'
  | 'accent'
  | 'sand'
  | 'soft'
  | 'inverse';
type BadgeSize = 'sm' | 'md' | 'lg';
type BadgeShape = 'pill' | 'rounded' | 'square' | 'tag';

interface Props {
  label?: string;
  tone?: BadgeTone;
  size?: BadgeSize;
  shape?: BadgeShape;
  /** @deprecated Prefer `tone`. Kept for back-compat. */
  variant?: 'default' | 'solid' | 'outline' | 'accent' | 'ink' | 'leather';
  density?: 'compact' | 'default' | 'loose';
  dot?: boolean;
  /** Optional inline icon (slot name: "icon-before"). */
  iconBefore?: boolean;
  /** Optional trailing icon (slot name: "icon-after"). */
  iconAfter?: boolean;
  href?: string;
  /** Optional secondary line shown above the label. */
  kicker?: string;
  /** Optional secondary line shown below the label. */
  meta?: string;
  /** Optional numeric suffix rendered as a tabular mini-chip. */
  count?: number | string;
  position?: 'inline' | 'absolute';
  disabled?: boolean;
  class?: string;
}

const {
  label,
  tone = 'neutral',
  size = 'md',
  shape = 'pill',
  variant,
  density = 'default',
  dot = false,
  iconBefore = false,
  iconAfter = false,
  href,
  kicker,
  meta,
  count,
  position = 'inline',
  disabled = false,
  class: className,
} = Astro.props;

const isLink = typeof href === 'string';
const isDisabled = isLink && disabled;

const variantClass = variant ? `badge--${variant}` : '';
const toneClass = `badge--${tone}`;

const baseClass = [
  'badge',
  variantClass,
  toneClass,
  `badge--${size}`,
  `badge--${shape}`,
  `badge--density-${density}`,
  dot && 'badge--dot',
  iconBefore && 'badge--has-icon-before',
  iconAfter && 'badge--has-icon-after',
  (kicker || meta) && 'badge--multi',
  count !== undefined && 'badge--has-count',
  position === 'absolute' && 'badge--absolute',
  isLink && 'badge--linked',
  isDisabled && 'is-disabled',
  className,
]
  .filter(Boolean)
  .join(' ');

const linkProps = isLink
  ? {
      href: isDisabled ? undefined : href,
      'aria-disabled': isDisabled ? ('true' as const) : undefined,
      'aria-label': label ?? undefined,
    }
  : {};
---

{
  isLink ? (
    <a class={baseClass} {...linkProps}>
      {iconBefore && (
        <span class="badge__icon badge__icon--before" aria-hidden="true">
          <slot name="icon-before" />
        </span>
      )}
      {kicker && <span class="badge__kicker">{kicker}</span>}
      <span class="badge__label">
        <slot>{label}</slot>
      </span>
      {meta && <span class="badge__meta">{meta}</span>}
      {count !== undefined && (
        <span class="badge__count" aria-hidden="true">
          {count}
        </span>
      )}
      {iconAfter && (
        <span class="badge__icon badge__icon--after" aria-hidden="true">
          <slot name="icon-after" />
        </span>
      )}
    </a>
  ) : (
    <span class={baseClass}>
      {iconBefore && (
        <span class="badge__icon badge__icon--before" aria-hidden="true">
          <slot name="icon-before" />
        </span>
      )}
      {kicker && <span class="badge__kicker">{kicker}</span>}
      <span class="badge__label">
        <slot>{label}</slot>
      </span>
      {meta && <span class="badge__meta">{meta}</span>}
      {count !== undefined && (
        <span class="badge__count" aria-hidden="true">
          {count}
        </span>
      )}
      {iconAfter && (
        <span class="badge__icon badge__icon--after" aria-hidden="true">
          <slot name="icon-after" />
        </span>
      )}
    </span>
  )
}

<style>
  /* =========================================================
     Badge · modern editorial chip.
     Generous radius, soft warm surface, hairline border.
     Zara / Mango / Pull&Bear level of refinement.
     ========================================================= */
  .badge {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    max-width: 100%;
    border: 1px solid color-mix(in srgb, var(--color-ink) 9%, transparent);
    background: var(--color-surface);
    color: var(--color-ink-soft);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-pill);
    font-variant-numeric: lining-nums tabular-nums;
    transition:
      transform var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out),
      background-color var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
  }

  /* =========================================================
     Shape.
     ========================================================= */
  .badge--pill {
    border-radius: var(--radius-pill);
  }

  .badge--rounded {
    border-radius: 14px;
  }

  .badge--square {
    border-radius: 10px;
  }

  .badge--tag {
    border-radius: 0;
    padding-inline: 0.7rem;
  }

  /* =========================================================
     Sizes.
     ========================================================= */
  .badge--sm {
    font-size: 0.62rem;
    padding: 0.38rem 0.7rem;
    gap: 0.35rem;
  }

  .badge--md {
    /* uses .badge defaults */
  }

  .badge--lg {
    font-size: 0.78rem;
    padding: 0.62rem 1.1rem;
    gap: 0.55rem;
  }

  /* =========================================================
     Density.
     ========================================================= */
  .badge--density-compact {
    padding-block: 0.34rem;
  }
  .badge--density-loose {
    padding-block: 0.7rem;
  }

  /* =========================================================
     Tones — modern editorial palette.
     ========================================================= */
  .badge--neutral {
    border-color: color-mix(in srgb, var(--color-ink) 9%, transparent);
    background: var(--color-surface);
    color: var(--color-ink-soft);
  }

  .badge--ink {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-inverse);
  }

  .badge--leather {
    border-color: var(--color-leather-dark);
    background: var(--color-leather-dark);
    color: var(--color-inverse);
  }

  .badge--outline {
    background: transparent;
    border-color: color-mix(in srgb, var(--color-ink) 20%, transparent);
    color: var(--color-ink);
  }

  .badge--accent {
    background: color-mix(in srgb, var(--color-leather) 12%, var(--color-surface));
    border-color: color-mix(in srgb, var(--color-leather) 22%, transparent);
    color: var(--color-leather-dark);
  }

  .badge--sand {
    background: color-mix(in srgb, var(--color-leather) 9%, var(--color-surface-soft));
    border-color: color-mix(in srgb, var(--color-leather) 18%, transparent);
    color: var(--color-leather-dark);
  }

  .badge--soft {
    background: var(--color-surface-soft);
    border-color: transparent;
    color: var(--color-ink-soft);
  }

  .badge--inverse {
    background: var(--color-surface-inverse);
    border-color: var(--color-surface-inverse);
    color: var(--color-inverse);
  }

  /* =========================================================
     Legacy variant aliases (back-compat).
     ========================================================= */
  .badge--default {
    background: var(--color-surface);
    border-color: color-mix(in srgb, var(--color-ink) 9%, transparent);
    color: var(--color-ink-soft);
  }
  .badge--solid {
    background: var(--color-surface-muted);
    border-color: transparent;
    color: var(--color-ink);
  }

  /* =========================================================
     Optional elements — kicker / meta / count / icons.
     ========================================================= */
  .badge__kicker,
  .badge__meta {
    font-size: 0.6rem;
    letter-spacing: 0.01em;
    font-weight: 500;
    color: currentColor;
    opacity: 0.7;
  }

  .badge__label {
    position: relative;
    z-index: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding-inline: 0.4rem;
    border-radius: var(--radius-pill);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0;
    background: color-mix(in srgb, currentColor 14%, transparent);
    color: currentColor;
  }

  .badge--ink .badge__count,
  .badge--leather .badge__count,
  .badge--inverse .badge__count {
    background: color-mix(in srgb, var(--color-inverse) 18%, transparent);
  }

  .badge__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    color: currentColor;
  }
  .badge__icon :global(svg) {
    width: 0.85rem;
    height: 0.85rem;
  }

  /* Multi-line badge — kicker above, meta below. */
  .badge--multi {
    align-items: flex-start;
    text-align: left;
    flex-direction: column;
    gap: 0.18rem;
    padding-block: 0.45rem;
    padding-inline: 0.85rem;
  }
  .badge--multi .badge__label {
    overflow: visible;
  }

  /* =========================================================
     Position — absolute variant anchors the badge to its
     containing media block. Soft blur for legibility.
     ========================================================= */
  .badge--absolute {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
    backdrop-filter: blur(10px) saturate(1.1);
    -webkit-backdrop-filter: blur(10px) saturate(1.1);
  }

  .badge--absolute.badge--neutral,
  .badge--absolute.badge--soft,
  .badge--absolute.badge--accent,
  .badge--absolute.badge--sand {
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
  }

  .badge--absolute.badge--outline {
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
  }

  /* =========================================================
     Link affordance — modern editorial lift.
     Soft translateY + color shift + warm shadow.
     ========================================================= */
  a.badge {
    cursor: pointer;
  }

  a.badge:hover,
  a.badge:focus-visible {
    transform: translateY(-1px);
    border-color: var(--color-ink);
    color: var(--color-ink);
    box-shadow: 0 6px 18px -10px rgb(23 18 14 / 0.22);
  }

  a.badge.badge--ink:hover,
  a.badge.badge--ink:focus-visible {
    border-color: var(--color-leather-dark);
    background: var(--color-leather-dark);
    color: var(--color-inverse);
    box-shadow: 0 6px 18px -10px rgb(118 80 51 / 0.32);
  }

  a.badge.badge--leather:hover,
  a.badge.badge--leather:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -10px rgb(118 80 51 / 0.32);
  }

  a.badge.badge--inverse:hover,
  a.badge.badge--inverse:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -10px rgb(0 0 0 / 0.4);
  }

  a.badge.badge--accent:hover,
  a.badge.badge--accent:focus-visible,
  a.badge.badge--sand:hover,
  a.badge.badge--sand:focus-visible {
    background: color-mix(in srgb, var(--color-leather) 18%, var(--color-surface));
    border-color: var(--color-leather-dark);
    color: var(--color-leather-dark);
  }

  a.badge.badge--soft:hover,
  a.badge.badge--soft:focus-visible {
    background: var(--color-surface);
    border-color: color-mix(in srgb, var(--color-ink) 18%, transparent);
    color: var(--color-ink);
  }

  a.badge.badge--outline:hover,
  a.badge.badge--outline:focus-visible {
    background: color-mix(in srgb, var(--color-ink) 4%, transparent);
    border-color: var(--color-ink);
  }

  a.badge:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  a.badge.is-disabled,
  a.badge[aria-disabled='true'] {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
    transform: none;
    box-shadow: none;
  }

  /* =========================================================
     Dot — small filled circle. Scales subtly on link hover.
     ========================================================= */
  .badge--dot::before {
    content: '';
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: var(--radius-pill);
    background: currentColor;
    flex: 0 0 auto;
    transition: transform var(--duration-base) var(--ease-out);
  }

  a.badge--dot:hover::before,
  a.badge--dot:focus-visible::before {
    transform: scale(1.3);
  }

  @media (prefers-reduced-motion: reduce) {
    .badge,
    .badge--dot::before {
      transition-duration: 1ms;
    }

    a.badge:hover,
    a.badge:focus-visible {
      transform: none;
    }
  }
</style>
