---
/**
 * Badge · modern editorial chip.
 *
 * Generous-radius chips for product tags, category markers,
 * status pills and featured callouts. Designed to feel
 * crafted-but-lively — Zara, Mango, Pull&Bear, Sfera level of
 * refinement. Less old-world stamp, more ecom presence.
 *
 * - Generous pill (default) / rounded / square shapes
 * - Soft warm surface with hairline border
 * - Modern lift + color shift + warm shadow on hover
 * - Filled circular dot (scales on hover)
 * - Subtle backdrop blur for absolute-positioned chips
 *   over media
 *
 * API is kept for backwards compatibility. `variant` and the
 * `sand` tone are still supported.
 */
type BadgeTone =
  | 'neutral'
  | 'ink'
  | 'leather'
  | 'outline'
  | 'accent'
  | 'sand'
  | 'soft'
  | 'inverse';
type BadgeSize = 'sm' | 'md' | 'lg';
type BadgeShape = 'pill' | 'rounded' | 'square' | 'tag';

interface Props {
  label?: string;
  tone?: BadgeTone;
  size?: BadgeSize;
  shape?: BadgeShape;
  /** @deprecated Prefer `tone`. Kept for back-compat. */
  variant?: 'default' | 'solid' | 'outline' | 'accent' | 'ink' | 'leather';
  density?: 'compact' | 'default' | 'loose';
  dot?: boolean;
  /** Optional inline icon (slot name: "icon-before"). */
  iconBefore?: boolean;
  /** Optional trailing icon (slot name: "icon-after"). */
  iconAfter?: boolean;
  href?: string;
  /** Optional secondary line shown above the label. */
  kicker?: string;
  /** Optional secondary line shown below the label. */
  meta?: string;
  /** Optional numeric suffix rendered as a tabular mini-chip. */
  count?: number | string;
  position?: 'inline' | 'absolute';
  disabled?: boolean;
  class?: string;
}

const {
  label,
  tone = 'neutral',
  size = 'md',
  shape = 'pill',
  variant,
  density = 'default',
  dot = false,
  iconBefore = false,
  iconAfter = false,
  href,
  kicker,
  meta,
  count,
  position = 'inline',
  disabled = false,
  class: className,
} = Astro.props;

const isLink = typeof href === 'string';
const isDisabled = isLink && disabled;

const variantClass = variant ? `badge--${variant}` : '';
const toneClass = `badge--${tone}`;

const baseClass = [
  'badge',
  variantClass,
  toneClass,
  `badge--${size}`,
  `badge--${shape}`,
  `badge--density-${density}`,
  dot && 'badge--dot',
  iconBefore && 'badge--has-icon-before',
  iconAfter && 'badge--has-icon-after',
  (kicker || meta) && 'badge--multi',
  count !== undefined && 'badge--has-count',
  position === 'absolute' && 'badge--absolute',
  isLink && 'badge--linked',
  isDisabled && 'is-disabled',
  className,
]
  .filter(Boolean)
  .join(' ');

const linkProps = isLink
  ? {
      href: isDisabled ? undefined : href,
      'aria-disabled': isDisabled ? ('true' as const) : undefined,
      'aria-label': label ?? undefined,
    }
  : {};
---

{
  isLink ? (
    <a class={baseClass} {...linkProps}>
      {iconBefore && (
        <span class="badge__icon badge__icon--before" aria-hidden="true">
          <slot name="icon-before" />
        </span>
      )}
      {kicker && <span class="badge__kicker">{kicker}</span>}
      <span class="badge__label">
        <slot>{label}</slot>
      </span>
      {meta && <span class="badge__meta">{meta}</span>}
      {count !== undefined && (
        <span class="badge__count" aria-hidden="true">
          {count}
        </span>
      )}
      {iconAfter && (
        <span class="badge__icon badge__icon--after" aria-hidden="true">
          <slot name="icon-after" />
        </span>
      )}
    </a>
  ) : (
    <span class={baseClass}>
      {iconBefore && (
        <span class="badge__icon badge__icon--before" aria-hidden="true">
          <slot name="icon-before" />
        </span>
      )}
      {kicker && <span class="badge__kicker">{kicker}</span>}
      <span class="badge__label">
        <slot>{label}</slot>
      </span>
      {meta && <span class="badge__meta">{meta}</span>}
      {count !== undefined && (
        <span class="badge__count" aria-hidden="true">
          {count}
        </span>
      )}
      {iconAfter && (
        <span class="badge__icon badge__icon--after" aria-hidden="true">
          <slot name="icon-after" />
        </span>
      )}
    </span>
  )
}

<style>
  /* =========================================================
     Badge · thin editorial chip.
     Built on the global .badge token (pill, hairline border,
     uppercase label). This layer adds the tone palette,
     the optional dot, the link affordance and the absolute
     media-overlay variant.
     ========================================================= */
  .badge {
    transition:
      color var(--duration-base) var(--ease-soft),
      background-color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft);
  }

  /* =========================================================
     Tones — neutral, ink, outline, soft, inverse.
     Warm "sand" / "leather" tones are kept as aliases that
     resolve to soft for back-compat, but never carry the
     warm shadow they used to.
     ========================================================= */
  .badge--neutral {
    background: var(--color-surface);
    border-color: var(--color-border);
    color: var(--color-ink-soft);
  }

  .badge--ink {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-inverse);
  }

  .badge--outline {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-ink);
  }

  .badge--soft {
    background: var(--color-surface-soft);
    border-color: transparent;
    color: var(--color-ink-soft);
  }

  .badge--inverse {
    background: var(--color-surface-inverse);
    border-color: var(--color-surface-inverse);
    color: var(--color-inverse);
  }

  /* Legacy warm tones — kept as aliases so the Style Museum
     and any external usage don't break. They resolve to soft. */
  .badge--sand,
  .badge--leather,
  .badge--accent,
  .badge--default,
  .badge--solid {
    background: var(--color-surface-soft);
    border-color: transparent;
    color: var(--color-ink-soft);
  }

  /* =========================================================
     Optional count — quiet tabular suffix.
     ========================================================= */
  .badge__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding-inline: 0.4rem;
    border-radius: var(--radius-pill);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0;
    background: color-mix(in srgb, currentColor 14%, transparent);
    color: currentColor;
  }

  .badge--ink .badge__count,
  .badge--inverse .badge__count {
    background: color-mix(in srgb, var(--color-inverse) 18%, transparent);
  }

  /* =========================================================
     Absolute variant — sits over a media block. Soft blur
     for legibility on top of photography.
     ========================================================= */
  .badge--absolute {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
    backdrop-filter: blur(10px) saturate(1.05);
    -webkit-backdrop-filter: blur(10px) saturate(1.05);
  }

  .badge--absolute.badge--neutral,
  .badge--absolute.badge--soft,
  .badge--absolute.badge--sand,
  .badge--absolute.badge--leather,
  .badge--absolute.badge--accent,
  .badge--absolute.badge--default,
  .badge--absolute.badge--solid {
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
  }

  .badge--absolute.badge--outline {
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
  }

  /* =========================================================
     Link affordance — quiet border + color shift. No lift.
     ========================================================= */
  a.badge {
    cursor: pointer;
  }

  a.badge:hover,
  a.badge:focus-visible {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }

  a.badge.badge--ink:hover,
  a.badge.badge--ink:focus-visible {
    background: var(--color-surface-muted);
    color: var(--color-ink);
  }

  a.badge.badge--outline:hover,
  a.badge.badge--outline:focus-visible {
    background: var(--color-surface-soft);
  }

  a.badge.badge--soft:hover,
  a.badge.badge--soft:focus-visible,
  a.badge.badge--sand:hover,
  a.badge.badge--sand:focus-visible,
  a.badge.badge--leather:hover,
  a.badge.badge--leather:focus-visible,
  a.badge.badge--accent:hover,
  a.badge.badge--accent:focus-visible {
    background: var(--color-surface);
    border-color: var(--color-border);
    color: var(--color-ink);
  }

  a.badge.badge--inverse:hover,
  a.badge.badge--inverse:focus-visible {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-inverse);
  }

  a.badge:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  a.badge.is-disabled,
  a.badge[aria-disabled='true'] {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* =========================================================
     Dot — small filled circle in currentColor.
     ========================================================= */
  .badge--dot::before {
    content: '';
    display: inline-block;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: var(--radius-pill);
    background: currentColor;
    flex: 0 0 auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .badge {
      transition-duration: 1ms;
    }
  }
</style>
