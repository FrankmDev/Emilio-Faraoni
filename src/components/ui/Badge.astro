---
interface Props {
  label?: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<span
  class={`inline-flex items-center border border-border bg-surface px-3 py-1 text-[0.6875rem] font-medium uppercase tracking-[0.15em] text-muted ${className || ''}`}
>
  <slot>{label}</slot>
</span>
