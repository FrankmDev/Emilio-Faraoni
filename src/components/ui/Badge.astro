---
import { cn } from '@/lib/utils';

interface Props {
  label?: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<span
  class={cn(
    'inline-flex items-center rounded-sm border border-border bg-white/70 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-leather-dark',
    className,
  )}
>
  <slot>{label}</slot>
</span>
