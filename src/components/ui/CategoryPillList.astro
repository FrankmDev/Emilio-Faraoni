---
/**
 * CategoryPillList · editorial filter strip.
 * A quiet, type-only filter row. Each pill is a small uppercase
 * label; the active state reveals a thin underline. No filled
 * chips, no SaaS corners, no app-like count badges.
 *
 * The `bordered` variant is opt-in and re-introduces the
 * chip-shaped pill (rounded with hairline border) for cases
 * that need a stronger filter presence, e.g. inside a card.
 */
export interface CategoryPillItem {
  label: string;
  href: string;
  /** Optional count rendered as a tabular suffix. Hidden by
   *  default to keep the strip quiet. */
  count?: number | string;
  /** Optional disabled state — pill renders as inert span. */
  disabled?: boolean;
}

type PillOrientation = 'horizontal' | 'scroll' | 'wrap';
type PillVariant = 'underline' | 'bordered';
type PillDensity = 'compact' | 'default' | 'loose';
type PillSize = 'sm' | 'md';

interface Props {
  categories: Array<CategoryPillItem>;
  active?: string;
  /** Visual treatment: 'underline' (default) for an editorial
   *  type-only filter, 'bordered' for chip-shaped pills. */
  variant?: PillVariant;
  /** Layout orientation. 'horizontal' wraps, 'scroll' is a
   *  horizontal scrollable strip, 'wrap' forces a wrapped grid. */
  orientation?: PillOrientation;
  density?: PillDensity;
  /** Overall size of the pills. */
  size?: PillSize;
  /** Show a leading 01/02/03 monogram on each pill. */
  withIndex?: boolean;
  /** Show a small tabular count suffix on each pill. */
  withCount?: boolean;
  /** Optional leading slot (slot name: "leading"). */
  class?: string;
}

const {
  categories,
  active,
  variant = 'underline',
  orientation = 'wrap',
  density = 'default',
  size = 'md',
  withIndex = false,
  withCount = false,
  class: className,
} = Astro.props;

const classes = [
  'pill-list',
  `pill-list--${variant}`,
  `pill-list--${orientation}`,
  `pill-list--density-${density}`,
  `pill-list--size-${size}`,
  withIndex && 'pill-list--with-index',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<nav aria-label="Categorías" class={classes}>
  <ol class="pill-list__list" role="list">
    <slot name="leading" />
    {
      categories.map((item, index) => {
        const isActive = active === item.href || active === item.label;
        return (
          <li class="pill-list__item">
            {item.disabled ? (
              <span
                class:list={[
                  'pill',
                  variant === 'bordered' && 'pill--bordered',
                  'pill--disabled',
                ]}
                aria-disabled="true"
              >
                {withIndex && (
                  <span class="pill__index meta-label" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                )}
                <span class="pill__label">{item.label}</span>
                {withCount && item.count !== undefined && (
                  <span class="pill__count">{item.count}</span>
                )}
              </span>
            ) : (
              <a
                href={item.href}
                class:list={[
                  'pill',
                  variant === 'bordered' && 'pill--bordered',
                  isActive && 'pill--active',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {withIndex && (
                  <span class="pill__index meta-label" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                )}
                <span class="pill__label">{item.label}</span>
                {withCount && item.count !== undefined && (
                  <span
                    class="pill__count"
                    aria-label={`${item.count} elementos`}
                  >
                    {item.count}
                  </span>
                )}
              </a>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  /* =========================================================
     Pill list — editorial filter strip.
     The default 'underline' variant leans on the global .pill
     token (which is now an editorial underline). The optional
     'bordered' variant adds the chip-shaped .pill--bordered
     modifier from the same global token.
     ========================================================= */
  .pill-list {
    width: 100%;
  }

  .pill-list--scroll {
    overflow-x: auto;
    padding-bottom: 0.2rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }
  .pill-list--scroll .pill-list__list {
    flex-wrap: nowrap;
  }

  .pill-list--horizontal .pill-list__list,
  .pill-list--wrap .pill-list__list {
    flex-wrap: wrap;
  }

  .pill-list__list {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pill-list__item {
    flex: 0 0 auto;
  }

  /* The default gap lives in the global .pill-list token.
     When using the underline variant we tighten the gap so
     the strip reads as a single editorial line, not a row
     of chips. */
  .pill-list--underline .pill-list__list {
    gap: 0;
  }

  .pill-list--underline .pill-list__item + .pill-list__item {
    margin-left: clamp(0.85rem, 1.8vw, 1.4rem);
  }

  /* Bordered variant keeps the original chip feel. */
  .pill-list--bordered .pill-list__list {
    gap: 0.45rem;
  }

  /* =========================================================
     Density — internal padding tweaks. Kept minimal.
     Only the bordered variant honours these.
     ========================================================= */
  .pill-list--density-compact .pill--bordered {
    padding-block: 0.4rem;
  }
  .pill-list--density-loose .pill--bordered {
    padding-block: 0.62rem;
  }

  /* =========================================================
     Default (underline) pill — leave global rules intact.
     ========================================================= */
  .pill-list--underline .pill {
    min-height: 1.5rem;
  }

  /* =========================================================
     Bordered pill — chip-shaped. Mirrors the older chunkier
     language, kept for callers that need stronger chips.
     ========================================================= */
  .pill--bordered {
    min-height: 2rem;
    padding: 0.5rem 0.95rem;
    gap: 0.5rem;
  }

  .pill__label {
    position: relative;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Optional monogram index — small numeral in muted ink. */
  .pill__index {
    color: var(--color-muted-light);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 300;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1;
    font-variant-numeric: lining-nums tabular-nums;
    padding-right: 0.45rem;
    border-right: 1px solid var(--color-border);
    transition:
      color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft);
  }

  /* Optional count — quiet tabular suffix. Only renders when
     the consumer opts in with `withCount`. Hidden by default
     to keep the strip quiet. */
  .pill__count {
    position: relative;
    color: var(--color-muted-light);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    min-width: 1.4rem;
    padding: 0.1rem 0.3rem;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    text-align: center;
    transition:
      color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft);
  }

  /* =========================================================
     Bordered hover.
     ========================================================= */
  .pill--bordered:hover,
  .pill--bordered:focus-visible {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }

  .pill--bordered:hover .pill__count,
  .pill--bordered:focus-visible .pill__count,
  .pill--bordered:hover .pill__index,
  .pill--bordered:focus-visible .pill__index {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }

  /* =========================================================
     Active — restrained ink fill on the bordered variant.
     The underline variant inherits the global hairline
     treatment (no fill, just ink text + bottom rule).
     ========================================================= */
  .pill--bordered.pill--active {
    color: var(--color-inverse);
    border-color: var(--color-ink);
    background: var(--color-ink);
  }

  .pill--bordered.pill--active .pill__index {
    color: var(--color-inverse);
    border-color: color-mix(in srgb, var(--color-inverse) 28%, transparent);
  }

  .pill--bordered.pill--active .pill__count {
    color: var(--color-inverse);
    border-color: color-mix(in srgb, var(--color-inverse) 35%, transparent);
    background: transparent;
  }

  /* =========================================================
     Disabled — quiet muted state for unavailable categories.
     ========================================================= */
  .pill--disabled {
    color: var(--color-muted-light);
    border-style: dashed;
    cursor: not-allowed;
    opacity: 0.7;
  }

  /* Focus ring — tokenized, kept just outside the pill. */
  .pill:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 3px;
  }

  /* Mobile — the strip wraps cleanly, padding tightens.
     Scroll orientation collapses to wrap on small viewports
     so the user never has to swipe to see all options. */
  @media (max-width: 640px) {
    .pill-list--scroll .pill-list__list {
      flex-wrap: wrap;
      overflow-x: visible;
    }

    .pill--bordered {
      padding: 0.45rem 0.85rem;
      font-size: 0.6rem;
      letter-spacing: 0.12em;
    }

    .pill__label {
      max-width: 22ch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill,
    .pill__index,
    .pill__count {
      transition-duration: 1ms;
    }
  }
</style>
