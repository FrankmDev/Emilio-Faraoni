---
/**
 * CategoryPillList · editorial filter strip.
 * Atelier treatment: notched edge, index reveal, monogram,
 * and a corner stamp on active. Each pill is a quiet
 * editorial chip with a notched bottom corner, an active
 * rail, and a count chip.
 */
export interface CategoryPillItem {
  label: string;
  href: string;
  /** Optional count to render as a tabular number suffix. */
  count?: number | string;
  /** Optional disabled state — pill renders as inert span. */
  disabled?: boolean;
}

type PillOrientation = 'horizontal' | 'scroll' | 'wrap';
type PillVariant = 'pill' | 'flat' | 'tag';
type PillDensity = 'compact' | 'default' | 'loose';
type PillSize = 'sm' | 'md';

interface Props {
  categories: Array<CategoryPillItem>;
  active?: string;
  /** Visual treatment: 'pill' (default), 'flat', or 'tag'. */
  variant?: PillVariant;
  /** Layout orientation. 'horizontal' wraps, 'scroll' is a
   *  horizontal scrollable strip, 'wrap' forces a wrapped grid. */
  orientation?: PillOrientation;
  density?: PillDensity;
  /** Overall size of the pills. */
  size?: PillSize;
  /** Show a leading 01/02/03 monogram on each pill. */
  withIndex?: boolean;
  /** Optional leading slot (slot name: "leading"). */
  class?: string;
}

const {
  categories,
  active,
  variant = 'pill',
  orientation = 'wrap',
  density = 'default',
  size = 'md',
  withIndex = false,
  class: className,
} = Astro.props;

const classes = [
  'pill-list',
  `pill-list--${variant}`,
  `pill-list--${orientation}`,
  `pill-list--density-${density}`,
  `pill-list--size-${size}`,
  withIndex && 'pill-list--with-index',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<nav aria-label="Categorías" class={classes}>
  <ol class="pill-list__list" role="list">
    <slot name="leading" />
    {
      categories.map((item, index) => {
        const isActive = active === item.href || active === item.label;
        return (
          <li class="pill-list__item">
            {item.disabled ? (
              <span
                class:list={['pill', 'pill--disabled']}
                aria-disabled="true"
              >
                {withIndex && (
                  <span class="pill__index meta-label" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                )}
                <span class="pill__label">{item.label}</span>
                {item.count !== undefined && (
                  <span class="pill__count">{item.count}</span>
                )}
              </span>
            ) : (
              <a
                href={item.href}
                class:list={['pill', isActive && 'pill--active']}
                aria-current={isActive ? 'page' : undefined}
              >
                {withIndex && (
                  <span class="pill__index meta-label" aria-hidden="true">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                )}
                <span class="pill__label">{item.label}</span>
                {item.count !== undefined && (
                  <span
                    class="pill__count"
                    aria-label={`${item.count} elementos`}
                  >
                    {item.count}
                  </span>
                )}
              </a>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  /* =========================================================
     Pill list — atelier editorial filters. Each pill has a
     notched corner, a quiet monogram slot, a count chip,
     and a hairline rail. Active state is a fully filled
     ink capsule with a hairline frame and a corner stamp.
     ========================================================= */
  .pill-list {
    width: 100%;
  }

  .pill-list--scroll {
    overflow-x: auto;
    padding-bottom: 0.2rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }
  .pill-list--scroll .pill-list__list {
    flex-wrap: nowrap;
  }

  .pill-list--horizontal .pill-list__list {
    flex-wrap: wrap;
  }

  .pill-list--wrap .pill-list__list {
    flex-wrap: wrap;
  }

  .pill-list__list {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pill-list__item {
    flex: 0 0 auto;
  }

  /* =========================================================
     Density — internal padding tweaks.
     ========================================================= */
  .pill-list--density-compact .pill {
    padding-block: 0.45rem;
  }
  .pill-list--density-loose .pill {
    padding-block: 0.78rem;
  }

  /* =========================================================
     Base pill — notched corner via clip-path, hairline
     border, subtle elevation. Hover and active states refine
     the same surface rather than swapping it out.
     ========================================================= */
  .pill {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 2.4rem;
    padding: 0.6rem 1.1rem 0.6rem 1.2rem;
    border: 1px solid var(--color-border-hairline);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.78), rgb(255 255 255 / 0)),
      var(--color-surface);
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    font-variant-numeric: lining-nums tabular-nums;
    transition:
      color var(--duration-base) var(--ease-soft),
      background-color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft),
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-soft);
  }

  /* Bottom-right hairline that animates to a fuller rail on
     hover, and becomes the underline of an active pill. */
  .pill::before {
    content: '';
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.45rem;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.4);
    transform-origin: left center;
    transition:
      opacity var(--duration-base) var(--ease-soft),
      transform var(--duration-slow) var(--ease-out);
  }

  /* Corner stamp — a small diamond that animates in on the
     active state. */
  .pill::after {
    content: '';
    position: absolute;
    bottom: 0.55rem;
    right: 0.95rem;
    width: 0.34rem;
    height: 0.34rem;
    border-bottom: 1px solid currentColor;
    border-right: 1px solid currentColor;
    opacity: 0;
    transform: translate(2px, 2px) scale(0.6);
    transition:
      opacity var(--duration-base) var(--ease-soft),
      transform var(--duration-slow) var(--ease-out);
  }

  .pill__label {
    position: relative;
    z-index: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Optional monogram index — drawn as a small monogram chip. */
  .pill__index {
    color: var(--color-muted-light);
    font-family: var(--font-serif);
    font-size: 0.7rem;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1;
    font-variant-numeric: lining-nums tabular-nums;
    padding-right: 0.5rem;
    border-right: 1px solid var(--color-border-hairline);
    transition:
      color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft);
  }

  /* Optional count — quiet tabular suffix, becomes ink on hover. */
  .pill__count {
    position: relative;
    z-index: 1;
    color: var(--color-muted-light);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    min-width: 1.55rem;
    padding: 0.28rem 0.42rem;
    border: 1px solid var(--color-border-hairline);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface) 78%, transparent);
    text-align: center;
    transition: color var(--duration-base) var(--ease-soft);
  }

  /* =========================================================
     Variants.
     ========================================================= */
  .pill-list--flat .pill {
    border-radius: 10px;
    padding: 0.6rem 1.1rem;
  }

  .pill-list--tag .pill {
    border-radius: 0;
    padding: 0.55rem 1rem;
  }
  .pill-list--tag .pill::before,
  .pill-list--tag .pill::after {
    display: none;
  }

  /* Size — controls the overall type scale. */
  .pill-list--size-sm .pill {
    min-height: 2.1rem;
    padding: 0.45rem 0.95rem;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
  }

  /* =========================================================
     Hover — quiet border + text darken. No background flash.
     The hairline rail grows and the label darkens. No
     dramatic lift, no shadow.
     ========================================================= */
  .pill:hover,
  .pill:focus-visible {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }

  .pill:hover::before,
  .pill:focus-visible::before {
    opacity: 0.4;
    transform: scaleX(1);
  }

  .pill:hover .pill__count,
  .pill:focus-visible .pill__count {
    color: var(--color-ink);
  }

  .pill:hover .pill__index,
  .pill:focus-visible .pill__index {
    color: var(--color-ink);
    border-color: color-mix(in srgb, var(--color-ink) 30%, transparent);
  }

  /* =========================================================
     Active — restrained ink treatment. The pill flips to a
     fully filled ink capsule with ivory text, the rail is
     always drawn, the corner stamp pushes in.
     ========================================================= */
  .pill--active {
    color: var(--color-ink-on-inverse);
    border-color: var(--color-ink);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.05), rgb(255 255 255 / 0)),
      var(--color-ink);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.12);
  }

  .pill--active::before {
    background: var(--color-ink-on-inverse);
    opacity: 0.45;
    transform: scaleX(1);
  }

  .pill--active::after {
    border-color: var(--color-ink-on-inverse);
    opacity: 0.7;
    transform: translate(0, 0) scale(1);
  }

  .pill--active .pill__index {
    color: var(--color-ink-on-inverse);
    border-color: color-mix(
      in srgb,
      var(--color-ink-on-inverse) 28%,
      transparent
    );
  }

  .pill--active .pill__count {
    color: var(--color-ink-on-inverse);
    border-color: color-mix(
      in srgb,
      var(--color-ink-on-inverse) 35%,
      transparent
    );
    background: color-mix(
      in srgb,
      var(--color-ink-on-inverse) 12%,
      transparent
    );
  }

  /* =========================================================
     Disabled — quiet muted state for unavailable categories.
     ========================================================= */
  .pill--disabled {
    color: var(--color-muted-light);
    border-style: dashed;
    cursor: not-allowed;
    opacity: 0.7;
  }

  /* Focus ring — tokenized, kept just outside the pill. */
  .pill:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* Mobile — the strip wraps cleanly, padding tightens. */
  @media (max-width: 640px) {
    .pill {
      padding: 0.55rem 0.95rem;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill,
    .pill::before,
    .pill::after {
      transition-duration: 1ms;
    }

    .pill--active::after {
      transform: translate(2px, 2px) scale(0.6);
    }
  }
</style>
