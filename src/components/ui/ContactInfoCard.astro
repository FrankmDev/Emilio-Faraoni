---
/**
 * ContactInfoCard · atelier contact module.
 * Renders as <a> when `href` is provided, otherwise <div>.
 * Supports an optional inline icon, index, kicker line, meta
 * line, and a description. Custom monoline SVG icons are
 * available via the `icon` slot (or by passing `icon={true}`
 * to render the default ink mark).
 */
type CardAlign = 'start' | 'center';
type CardDensity = 'compact' | 'default' | 'loose';

interface Props {
  label: string;
  value: string;
  href?: string;
  description?: string;
  /** Optional kicker line shown above the label. */
  kicker?: string;
  /** Optional meta line shown below the description. */
  meta?: string;
  /** Inline icon. If `true` is passed, the default ink monogram
   *  is rendered; otherwise a custom SVG can be supplied via
   *  the `icon` slot. */
  icon?: boolean;
  /** Optional index number, zero-padded to two digits. */
  index?: number | string;
  align?: CardAlign;
  density?: CardDensity;
  /** Visual emphasis. 'frame' adds a hairline border,
   *  'minimal' removes the rail, 'plain' is a quiet block. */
  variant?: 'plain' | 'frame' | 'minimal';
  class?: string;
}

const {
  label,
  value,
  href,
  description,
  kicker,
  meta,
  icon = false,
  index,
  align = 'start',
  density = 'default',
  variant = 'plain',
  class: className,
} = Astro.props;

const isLink = typeof href === 'string';
const Tag = isLink ? 'a' : 'div';
const classes = [
  'contact-info',
  isLink && 'contact-info--linked',
  `contact-info--${variant}`,
  `contact-info--${align}`,
  `contact-info--density-${density}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const ariaLabel = isLink ? `${label}: ${value}` : undefined;
---

<Tag class={classes} href={isLink ? href : undefined} aria-label={ariaLabel}>
  <span class="contact-info__frame" aria-hidden="true"></span>
  {
    (icon || Astro.slots.has('icon')) && (
      <span class="contact-info__icon" aria-hidden="true">
        <slot name="icon">
          <svg
            width="22"
            height="22"
            viewBox="0 0 22 22"
            fill="none"
            stroke="currentColor"
            stroke-width="1.1"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3.5" y="6" width="15" height="11" rx="3" />
            <path d="M3.5 9.5h15" />
            <path d="M7 13.5h2" />
          </svg>
        </slot>
      </span>
    )
  }
  <span class="contact-info__body">
    {
      kicker && (
        <span class="contact-info__kicker meta-label" aria-hidden="true">
          {kicker}
        </span>
      )
    }
    <span class="contact-info__row">
      {
        index !== undefined && (
          <span class="contact-info__index meta-label" aria-hidden="true">
            {String(index).padStart(2, '0')}
          </span>
        )
      }
      <span class="contact-info__label meta-label">{label}</span>
    </span>
    <span class="contact-info__value">{value}</span>
    {
      description && (
        <span class="contact-info__description copy-small">{description}</span>
      )
    }
    {
      meta && (
        <span class="contact-info__meta meta-label" aria-hidden="true">
          {meta}
        </span>
      )
    }
  </span>
  {
    isLink && (
      <span class="contact-info__arrow" aria-hidden="true">
        <svg
          width="14"
          height="10"
          viewBox="0 0 14 10"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M1 5h12" />
          <path d="M9 1l4 4-4 4" />
        </svg>
      </span>
    )
  }
</Tag>

<style>
  /* =========================================================
     Contact info — atelier module. Generous radius, layered
     frame, dramatic icon treatment, hairline rail with
     monogram index. The whole card shifts up on hover with
     the inner frame retreating.
     ========================================================= */
  .contact-info {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: start;
    gap: 1.4rem;
    padding: 1.6rem 1.5rem 1.6rem 1.6rem;
    border: 1px solid var(--color-border-hairline);
    border-radius: var(--radius-card-lg);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.85), rgb(255 255 255 / 0.4)),
      var(--color-surface);
    text-decoration: none;
    color: var(--color-ink);
    transition:
      border-color var(--duration-base) var(--ease-soft),
      transform var(--duration-slow) var(--ease-out),
      box-shadow var(--duration-slow) var(--ease-soft);
  }

  /* Inset frame — a quiet second border that retreats on
     hover, giving the card a "second skin" feel. */
  .contact-info__frame {
    position: absolute;
    inset: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-ink) 6%, transparent);
    border-radius: calc(var(--radius-card-lg) - 6px);
    pointer-events: none;
    transition:
      inset var(--duration-slow) var(--ease-out),
      border-color var(--duration-base) var(--ease-soft);
  }

  /* =========================================================
     Variants.
     ========================================================= */
  .contact-info--frame {
    border-color: var(--color-border);
  }

  .contact-info--minimal {
    border: 0;
    background: transparent;
    padding: 1.2rem 0;
  }
  .contact-info--minimal .contact-info__frame {
    display: none;
  }

  /* Static (no link) — drops the arrow column. */
  .contact-info:not(.contact-info--linked) {
    grid-template-columns: auto minmax(0, 1fr);
  }

  /* Linked affordance — cursor + arrow column. No dramatic
     lift; the inner frame retreats, the border darkens, the
     arrow slides right. */
  .contact-info--linked {
    cursor: pointer;
  }

  .contact-info--linked:hover,
  .contact-info--linked:focus-visible {
    border-color: var(--color-ink);
  }

  .contact-info--linked:hover .contact-info__frame,
  .contact-info--linked:focus-visible .contact-info__frame {
    inset: 0.75rem;
    border-color: color-mix(in srgb, var(--color-ink) 18%, transparent);
  }

  /* =========================================================
     Density.
     ========================================================= */
  .contact-info--density-compact {
    padding: 1.1rem 1.1rem 1.1rem 1.2rem;
    gap: 0.95rem;
  }
  .contact-info--density-loose {
    padding: 2.1rem 1.8rem 2.1rem 1.9rem;
    gap: 1.5rem;
  }

  /* =========================================================
     Icon — larger, more sculptural. Monoline SVG sits inside
     a hairline-bordered panel; the panel scales and the
     icon's colour shifts on hover.
     ========================================================= */
  .contact-info__icon {
    grid-row: span 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    margin-top: 0.2rem;
    border: 1px solid var(--color-border-hairline);
    border-radius: var(--radius-card);
    color: var(--color-ink-soft);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.9), rgb(255 255 255 / 0)),
      var(--color-surface);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.85),
      0 1px 0 color-mix(in srgb, var(--color-ink) 4%, transparent);
    transition:
      color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft),
      background-color var(--duration-base) var(--ease-soft),
      transform var(--duration-slow) var(--ease-out);
  }

  .contact-info__icon :global(svg),
  .contact-info__icon svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .contact-info--linked:hover .contact-info__icon,
  .contact-info--linked:focus-visible .contact-info__icon {
    color: var(--color-ink);
    border-color: var(--color-ink);
    background:
      linear-gradient(180deg, rgb(255 254 251 / 0.95), rgb(255 254 251 / 0.4)),
      var(--color-surface);
  }

  /* Body — flex column. */
  .contact-info__body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }

  .contact-info__row {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
  }

  .contact-info__kicker {
    color: var(--color-ink-soft);
  }

  .contact-info__index {
    color: var(--color-ink-soft);
    font-variant-numeric: lining-nums tabular-nums;
    padding: 0.18rem 0.45rem;
    border: 1px solid var(--color-border-hairline);
    border-radius: 4px;
    background: var(--color-surface);
  }

  .contact-info__label {
    color: var(--color-muted);
  }

  .contact-info__value {
    color: var(--color-ink);
    text-wrap: balance;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(1.15rem, 1.5vw, 1.35rem);
    line-height: 1.25;
    letter-spacing: -0.005em;
    transition: color var(--duration-base) var(--ease-soft);
  }

  .contact-info__description {
    color: var(--color-muted);
    max-width: 38ch;
  }

  .contact-info__meta {
    color: var(--color-ink-soft);
    border-top: 1px solid var(--color-border-hairline);
    padding-top: 0.55rem;
    margin-top: 0.25rem;
  }

  /* Arrow — only present on linked variants. */
  .contact-info__arrow {
    grid-row: span 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    margin-top: 0.2rem;
    border: 1px solid var(--color-border-hairline);
    border-radius: 999px;
    color: var(--color-muted);
    background: var(--color-surface);
    transition:
      color var(--duration-base) var(--ease-soft),
      border-color var(--duration-base) var(--ease-soft),
      transform var(--duration-base) var(--ease-out);
  }

  .contact-info__arrow :global(svg),
  .contact-info__arrow svg {
    width: 14px;
    height: 10px;
  }

  .contact-info--linked:hover .contact-info__value,
  .contact-info--linked:focus-visible .contact-info__value {
    color: var(--color-ink);
  }

  .contact-info--linked:hover .contact-info__arrow,
  .contact-info--linked:focus-visible .contact-info__arrow {
    color: var(--color-ink);
    border-color: var(--color-ink);
    transform: translateX(3px);
  }

  /* Alignment */
  .contact-info--center {
    text-align: center;
    justify-items: center;
  }
  .contact-info--center .contact-info__body {
    align-items: center;
  }
  .contact-info--center .contact-info__row {
    justify-content: center;
  }

  /* Focus ring — tokenized, generous offset. */
  .contact-info--linked:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-info,
    .contact-info__frame,
    .contact-info__icon,
    .contact-info__value,
    .contact-info__arrow {
      transition-duration: 1ms;
    }
  }

  /* Mobile — value tightens, icon and arrow stay. */
  @media (max-width: 640px) {
    .contact-info {
      gap: 1rem;
      padding: 1.25rem 1.15rem;
    }

    .contact-info__value {
      font-size: 1.05rem;
    }
  }
</style>
