---
/**
 * ContactInfoCard · editorial contact line.
 * Renders as <a> when `href` is provided, otherwise <div>.
 * Built on the global `.contact-card` token (hairline
 * separator, full-width row). This layer adds the index /
 * label / value / description / meta composition and the
 * optional link affordance.
 */
type CardAlign = 'start' | 'center';
type CardDensity = 'compact' | 'default' | 'loose';

interface Props {
  label: string;
  value: string;
  href?: string;
  description?: string;
  /** Optional kicker line shown above the label. */
  kicker?: string;
  /** Optional meta line shown below the description. */
  meta?: string;
  /** Inline icon. If `true` is passed, the default ink monogram
   *  is rendered; otherwise a custom SVG can be supplied via
   *  the `icon` slot. */
  icon?: boolean;
  /** Optional index number, zero-padded to two digits. */
  index?: number | string;
  align?: CardAlign;
  density?: CardDensity;
  /** Visual emphasis. 'frame' adds a hairline border,
   *  'minimal' removes the rail, 'plain' is a quiet block. */
  variant?: 'plain' | 'frame' | 'minimal';
  class?: string;
}

const {
  label,
  value,
  href,
  description,
  kicker,
  meta,
  icon = false,
  index,
  align = 'start',
  density = 'default',
  variant = 'plain',
  class: className,
} = Astro.props;

const isLink = typeof href === 'string';
const Tag = isLink ? 'a' : 'div';
const classes = [
  'contact-card',
  'contact-info',
  isLink && 'contact-info--linked',
  `contact-info--${variant}`,
  `contact-info--${align}`,
  `contact-info--density-${density}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const ariaLabel = isLink ? `${label}: ${value}` : undefined;
---

<Tag class={classes} href={isLink ? href : undefined} aria-label={ariaLabel}>
  {
    (icon || Astro.slots.has('icon')) && (
      <span class="contact-info__icon" aria-hidden="true">
        <slot name="icon">
          <svg
            width="22"
            height="22"
            viewBox="0 0 22 22"
            fill="none"
            stroke="currentColor"
            stroke-width="1.1"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3.5" y="6" width="15" height="11" rx="3" />
            <path d="M3.5 9.5h15" />
            <path d="M7 13.5h2" />
          </svg>
        </slot>
      </span>
    )
  }
  <span class="contact-info__body">
    {
      kicker && (
        <span class="contact-info__kicker meta-label" aria-hidden="true">
          {kicker}
        </span>
      )
    }
    <span class="contact-info__row">
      {
        index !== undefined && (
          <span class="contact-info__index meta-label" aria-hidden="true">
            {String(index).padStart(2, '0')}
          </span>
        )
      }
      <span class="contact-info__label meta-label">{label}</span>
    </span>
    <span class="contact-info__value">{value}</span>
    {
      description && (
        <span class="contact-info__description copy-small">{description}</span>
      )
    }
    {
      meta && (
        <span class="contact-info__meta meta-label" aria-hidden="true">
          {meta}
        </span>
      )
    }
  </span>
  {
    isLink && (
      <span class="contact-info__arrow" aria-hidden="true">
        <svg
          width="14"
          height="10"
          viewBox="0 0 14 10"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M1 5h12" />
          <path d="M9 1l4 4-4 4" />
        </svg>
      </span>
    )
  }
</Tag>

<style>
  /* =========================================================
     Contact info — editorial line module.
     The global `.contact-card` token supplies the hairline
     separator + vertical rhythm. This layer adds the index /
     label / value / arrow composition and the link affordance.
     ========================================================= */
  .contact-info {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 0.5rem 1.5rem;
    padding-block: 1.15rem;
    text-decoration: none;
    color: var(--color-ink);
    transition: color var(--duration-base) var(--ease-soft);
  }

  /* Suppress the global top border when the card is the
     first child of a list — the parent list owns that. */
  .contact-info:first-child,
  .contact-info.contact-card:first-child {
    border-top: 0;
  }

  /* =========================================================
     Variants.
     ========================================================= */
  .contact-info--frame {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.25rem 1.4rem;
  }

  .contact-info--frame.contact-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .contact-info--minimal {
    border: 0;
    padding-block: 0.85rem;
  }

  /* =========================================================
     Density.
     ========================================================= */
  .contact-info--density-compact {
    padding-block: 0.95rem;
  }
  .contact-info--density-loose {
    padding-block: 1.75rem;
  }

  /* =========================================================
     Icon — small inline mark, only if requested.
     ========================================================= */
  .contact-info__icon {
    grid-row: span 2;
    grid-column: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-muted);
  }

  .contact-info__icon :global(svg),
  .contact-info__icon svg {
    width: 1rem;
    height: 1rem;
  }

  /* Body — flex column. */
  .contact-info__body {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .contact-info__row {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
  }

  .contact-info__kicker {
    color: var(--color-muted);
  }

  .contact-info__index {
    color: var(--color-muted);
    font-variant-numeric: lining-nums tabular-nums;
  }

  .contact-info__label {
    color: var(--color-muted);
  }

  .contact-info__value {
    color: var(--color-ink);
    text-wrap: balance;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.4;
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }

  .contact-info--linked .contact-info__value {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 24%, transparent);
    text-underline-offset: 0.18em;
    transition:
      color var(--duration-base) var(--ease-soft),
      text-decoration-color var(--duration-base) var(--ease-soft);
  }

  .contact-info__description {
    color: var(--color-muted);
    max-width: 38ch;
  }

  .contact-info__meta {
    color: var(--color-muted);
  }

  /* Arrow — only present on linked variants, sits in the
     right column. Quiet, no slide, no panel. */
  .contact-info__arrow {
    grid-row: span 2;
    grid-column: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--color-muted);
    transition: color var(--duration-base) var(--ease-soft);
  }

  .contact-info__arrow :global(svg),
  .contact-info__arrow svg {
    width: 14px;
    height: 10px;
  }

  .contact-info--linked {
    cursor: pointer;
  }

  .contact-info--linked:hover .contact-info__value,
  .contact-info--linked:focus-visible .contact-info__value {
    color: var(--color-ink);
    text-decoration-color: currentColor;
  }

  .contact-info--linked:hover .contact-info__arrow,
  .contact-info--linked:focus-visible .contact-info__arrow {
    color: var(--color-ink);
  }

  /* Alignment */
  .contact-info--center {
    text-align: center;
    justify-items: center;
  }
  .contact-info--center .contact-info__body {
    align-items: center;
  }
  .contact-info--center .contact-info__row {
    justify-content: center;
  }

  /* Focus ring — global shorthand. */
  .contact-info--linked:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* Mobile — value tightens, structure unchanged. */
  @media (max-width: 640px) {
    .contact-info {
      gap: 0.5rem 1rem;
    }

    .contact-info__value {
      font-size: 1rem;
    }
  }
</style>
