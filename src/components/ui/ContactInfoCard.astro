---
/**
 * ContactInfoCard · editorial contact card.
 *
 * Minimal, editorial card where the contact value is the
 * hero — set in Fraunces, large, almost like letterpress
 * on thick stock. The label is a tiny architectural eyebrow.
 * No descriptions, no arrows, no clutter.
 *
 *   ┌────────────────────────────────────────┐
 *   │                                        │
 *   │  ╭───╮  CORREO ELECTRÓNICO             │
 *   │  │ ✉ │  hola@emiliofaraoni.com         │
 *   │  ╰───╯                                 │
 *   │                                        │
 *   └────────────────────────────────────────┘
 */

type IconName = 'email' | 'phone' | 'location' | 'hours';

interface Props {
  label: string;
  value: string;
  href?: string;
  icon?: IconName;
  class?: string;
}

const { label, value, href, icon, class: className } = Astro.props;

const isLink = typeof href === 'string';
const Tag = isLink ? 'a' : 'div';
---

<Tag
  class:list={['contact-info', isLink && 'contact-info--linked', className]}
  href={isLink ? href : undefined}
  aria-label={isLink ? `${label}: ${value}` : undefined}
>
  {
    icon && (
      <span class="contact-info__icon" aria-hidden="true">
        {icon === 'email' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2.5" y="5.5" width="19" height="13" rx="2" />
            <path d="M3 7.5l9 6 9-6" />
          </svg>
        )}
        {icon === 'phone' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="2.5" width="12" height="19" rx="3" />
            <line x1="10.5" y1="18.5" x2="13.5" y2="18.5" />
          </svg>
        )}
        {icon === 'location' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s-7-7.5-7-13a7 7 0 0 1 14 0c0 5.5-7 13-7 13z" />
            <circle cx="12" cy="9" r="2.5" />
          </svg>
        )}
        {icon === 'hours' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9.5" />
            <path d="M12 7v5l3.5 2" />
          </svg>
        )}
      </span>
    )
  }

  <div class="contact-info__body">
    <span class="contact-info__label">{label}</span>
    <p class="contact-info__value">{value}</p>
  </div>
</Tag>

<style>
  .contact-info {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.75rem 2rem;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-ink);
    transition:
      border-color var(--duration-slow) var(--ease-out),
      background-color var(--duration-slow) var(--ease-out);
  }

  .contact-info--linked {
    cursor: pointer;
  }

  .contact-info--linked:hover,
  .contact-info--linked:focus-visible {
    border-color: var(--color-leather-dark);
  }

  .contact-info--linked:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .contact-info__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-leather-dark);
    flex: 0 0 auto;
    transition:
      color var(--duration-slow) var(--ease-out),
      background-color var(--duration-slow) var(--ease-out),
      border-color var(--duration-slow) var(--ease-out);
  }

  .contact-info__icon svg {
    width: 1rem;
    height: 1rem;
  }

  .contact-info--linked:hover .contact-info__icon,
  .contact-info--linked:focus-visible .contact-info__icon {
    background: var(--color-leather-dark);
    border-color: var(--color-leather-dark);
    color: var(--color-inverse);
  }

  .contact-info__body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
    flex: 1;
    padding-top: 0.1rem;
  }

  .contact-info__label {
    display: block;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 650;
    letter-spacing: 0.17em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .contact-info__value {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.025em;
    overflow-wrap: anywhere;
    transition: color var(--duration-slow) var(--ease-out);
  }

  .contact-info--linked:hover .contact-info__value,
  .contact-info--linked:focus-visible .contact-info__value {
    color: var(--color-leather-dark);
  }

  @media (max-width: 640px) {
    .contact-info {
      padding: 1.35rem 1.4rem;
      gap: 1rem;
    }

    .contact-info__icon {
      width: 2.15rem;
      height: 2.15rem;
    }

    .contact-info__icon svg {
      width: 0.9rem;
      height: 0.9rem;
    }

    .contact-info__body {
      gap: 0.45rem;
    }

    .contact-info__value {
      font-size: 1.15rem;
    }
  }
</style>
