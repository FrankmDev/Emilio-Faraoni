---
/**
 * FeaturedCard · editorial feature module.
 * Renders as <a> when `href` is provided, otherwise <article>.
 * Built on the global `.feature-card` token — open, hairline-
 * bordered, magazine-spread composition. Optional media with
 * a clean image plane, optional top rail (index + kicker +
 * eyebrow), optional meta line and an optional `hover-line-
 * grow` rail.
 *
 * Designed to carry brand differentiators: empresa familiar,
 * fabricación nacional, materiales nacionales, alta calidad.
 */
type FeaturedVariant = 'default' | 'minimal' | 'dark';
type MediaAspect = '4/5' | '3/4' | '1/1' | '16/9' | '21/9' | '2/3';
type MediaFit = 'cover' | 'contain';
type FeaturedAlign = 'start' | 'center';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  index?: number | string;
  href?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number | string;
  imageHeight?: number | string;
  variant?: FeaturedVariant;
  align?: FeaturedAlign;
  mediaAspect?: MediaAspect;
  mediaFit?: MediaFit;
  kicker?: string;
  meta?: string;
  caption?: string;
  rail?: boolean;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  index,
  href,
  image,
  imageAlt,
  imageWidth = 960,
  imageHeight = 1200,
  variant = 'default',
  align = 'start',
  mediaAspect = '4/5',
  mediaFit = 'cover',
  kicker,
  meta,
  caption,
  rail = false,
  class: className,
} = Astro.props;

const isLink = typeof href === 'string';
const Tag = isLink ? 'a' : 'article';
const variantClass =
  variant === 'dark'
    ? 'feature-card-dark'
    : variant === 'minimal'
      ? 'feature-card-minimal'
      : 'feature-card';

const classes = [
  variantClass,
  `featured-card--align-${align}`,
  isLink && 'featured-card--linked',
  image && 'featured-card--has-image',
  className,
]
  .filter(Boolean)
  .join(' ');

const ariaLabel = isLink ? title : undefined;
const mediaStyle = `aspect-ratio: ${mediaAspect};`;
---

<Tag class={classes} href={isLink ? href : undefined} aria-label={ariaLabel}>
  {
    image && (
      <figure class="featured-card__media" style={mediaStyle}>
        <img
          src={image}
          alt={imageAlt ?? ''}
          width={imageWidth}
          height={imageHeight}
          loading="lazy"
          decoding="async"
          class={`featured-card__image transition-media featured-card__image--fit-${mediaFit}`}
        />
        {caption && (
          <span class="featured-card__caption label-fine" aria-hidden="true">
            {caption}
          </span>
        )}
      </figure>
    )
  }

  <div class="featured-card__top">
    {
      index !== undefined && (
        <span class="featured-card__index" aria-hidden="true">
          {String(index).padStart(2, '0')}
        </span>
      )
    }
    {kicker && <span class="featured-card__kicker meta-label">{kicker}</span>}
    {eyebrow && <p class="eyebrow featured-card__eyebrow">{eyebrow}</p>}
    {
      meta && (
        <span class="featured-card__meta meta-label" aria-hidden="true">
          {meta}
        </span>
      )
    }
  </div>

  <div class="featured-card__body">
    <h3 class="heading-card featured-card__title">{title}</h3>
    <p class="copy-small featured-card__description truncate-3">
      {description}
    </p>
    {
      rail && (
        <span class="featured-card__rail" aria-hidden="true">
          <span class="hover-line-grow" />
        </span>
      )
    }
  </div>
</Tag>
