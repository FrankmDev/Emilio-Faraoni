---
/**
 * FeaturedCard · editorial tile, atelier edition.
 * Renders as <a> when `href` is provided, otherwise <article>.
 * Optional `image` prop places an editorial image on top.
 * Internal structure: media (optional) → top rail → title →
 * description → meta → rail. Uses the larger atelier radius
 * and a layered frame for confidence.
 */
type FeaturedVariant = 'default' | 'subtle' | 'frame' | 'minimal';
type MediaAspect = '4/5' | '3/4' | '1/1' | '16/9' | '21/9' | '2/3';
type MediaFit = 'cover' | 'contain';
type FeaturedAlign = 'start' | 'center';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  index?: number | string;
  href?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number | string;
  imageHeight?: number | string;
  /** Visual emphasis. 'subtle' = flat, 'frame' = stronger
   *  border, 'minimal' = no border at all. */
  variant?: FeaturedVariant;
  align?: FeaturedAlign;
  /** Aspect ratio of the media block. */
  mediaAspect?: MediaAspect;
  /** Object-fit of the image. */
  mediaFit?: MediaFit;
  /** Optional kicker line above the eyebrow. */
  kicker?: string;
  /** Optional meta line below the description. */
  meta?: string;
  /** Optional caption rendered as a small label inside the media. */
  caption?: string;
  /** Show the bottom rail. Defaults to true. */
  rail?: boolean;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  index,
  href,
  image,
  imageAlt,
  imageWidth = 960,
  imageHeight = 1200,
  variant = 'default',
  align = 'start',
  mediaAspect = '4/5',
  mediaFit = 'cover',
  kicker,
  meta,
  caption,
  rail = true,
  class: className,
} = Astro.props;

const isLink = typeof href === 'string';
const Tag = isLink ? 'a' : 'article';
const classes = [
  'featured-card',
  `featured-card--${variant}`,
  `featured-card--align-${align}`,
  isLink && 'featured-card--linked',
  image && 'featured-card--has-image',
  className,
]
  .filter(Boolean)
  .join(' ');

const ariaLabel = isLink ? title : undefined;
const mediaStyle = `aspect-ratio: ${mediaAspect};`;
---

<Tag class={classes} href={isLink ? href : undefined} aria-label={ariaLabel}>
  <span class="featured-card__frame" aria-hidden="true"></span>
  {
    image && (
      <figure class="featured-card__media" style={mediaStyle}>
        <img
          src={image}
          alt={imageAlt ?? ''}
          width={imageWidth}
          height={imageHeight}
          loading="lazy"
          decoding="async"
          class={`featured-card__image featured-card__image--fit-${mediaFit}`}
        />
        <span class="featured-card__media-corner" aria-hidden="true" />
        {caption && (
          <span class="featured-card__caption label-fine" aria-hidden="true">
            {caption}
          </span>
        )}
      </figure>
    )
  }
  <div class="featured-card__body">
    <div class="featured-card__top">
      {
        index !== undefined && (
          <span class="featured-card__index meta-label" aria-hidden="true">
            {String(index).padStart(2, '0')}
          </span>
        )
      }
      {
        kicker && (
          <p class="featured-card__kicker meta-label" aria-hidden="true">
            {kicker}
          </p>
        )
      }
      {eyebrow && <p class="eyebrow featured-card__eyebrow">{eyebrow}</p>}
    </div>
    <h3 class="heading-card featured-card__title">{title}</h3>
    <p class="copy-small featured-card__description">{description}</p>
    {
      meta && (
        <p class="featured-card__meta meta-label" aria-hidden="true">
          {meta}
        </p>
      )
    }
    {
      rail && (
        <span class="featured-card__rail" aria-hidden="true">
          <span class="featured-card__rail-line" />
          <span class="featured-card__rail-arrow" />
        </span>
      )
    }
  </div>
</Tag>

<style>
  /* =========================================================
     Atelier featured card — generous radius, layered frame,
     dramatic hover lift. The card body and media are two
     distinct surfaces; the frame and rail are micro-details
     that compose the editorial feel.
     ========================================================= */
  .featured-card {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    height: 100%;
    padding: 1.5rem;
    border: 1px solid var(--color-border-hairline);
    background:
      linear-gradient(
        180deg,
        rgb(255 255 255 / 0.85) 0%,
        rgb(255 255 255 / 0.4) 100%
      ),
      var(--color-surface);
    border-radius: var(--radius-card-lg);
    color: var(--color-ink);
    text-decoration: none;
    overflow: hidden;
    transition:
      border-color var(--duration-base) var(--ease-soft),
      background-color var(--duration-base) var(--ease-soft),
      transform var(--duration-slow) var(--ease-out),
      box-shadow var(--duration-slow) var(--ease-soft);
  }

  /* Layered frame — sits 6px inside the card. Expands outward
     on hover to give a "second frame" effect. */
  .featured-card__frame {
    position: absolute;
    inset: 0.42rem;
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: calc(var(--radius-card-lg) - 4px);
    pointer-events: none;
    transition:
      inset var(--duration-slow) var(--ease-out),
      border-color var(--duration-base) var(--ease-soft);
  }

  /* Corner stamp — tiny bottom-right ornament that follows
     the active frame. */
  .featured-card::after {
    content: '';
    position: absolute;
    bottom: 1.1rem;
    right: 1.1rem;
    width: 0.5rem;
    height: 0.5rem;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-ink) 50%, transparent);
    border-right: 1px solid
      color-mix(in srgb, var(--color-ink) 50%, transparent);
    opacity: 0.35;
    z-index: 0;
    transition:
      opacity var(--duration-base) var(--ease-soft),
      transform var(--duration-base) var(--ease-out);
  }

  /* =========================================================
     Variants.
     ========================================================= */
  .featured-card--subtle {
    border-color: transparent;
    background: transparent;
  }
  .featured-card--subtle .featured-card__frame {
    display: none;
  }

  .featured-card--frame {
    border-color: var(--color-border);
    box-shadow: var(--atelier-shadow);
  }

  .featured-card--minimal {
    border: 0;
    background: transparent;
    padding: 0.5rem 0;
  }
  .featured-card--minimal .featured-card__frame,
  .featured-card--minimal::after {
    display: none;
  }

  /* Image variant — drops body padding; image is the surface. */
  .featured-card--has-image {
    padding: 0;
    border-color: var(--color-border-hairline);
  }
  .featured-card--has-image .featured-card__frame {
    inset: 0.55rem;
  }

  /* Alignment */
  .featured-card--align-center .featured-card__body {
    text-align: center;
    align-items: center;
  }

  /* =========================================================
     Linked affordance — quiet hover. The inner frame
     retreats, the border darkens, the corner stamp sharpens.
     No SaaS lift, no big shadow.
     ========================================================= */
  .featured-card--linked {
    cursor: pointer;
  }

  .featured-card--linked:hover,
  .featured-card--linked:focus-visible {
    border-color: var(--color-ink);
  }

  .featured-card--linked:hover .featured-card__frame,
  .featured-card--linked:focus-visible .featured-card__frame {
    inset: 0.7rem;
    border-color: color-mix(in srgb, var(--color-ink) 22%, transparent);
  }

  .featured-card--linked:hover::after,
  .featured-card--linked:focus-visible::after {
    opacity: 0.8;
  }

  .featured-card--subtle.featured-card--linked:hover,
  .featured-card--subtle.featured-card--linked:focus-visible {
    border-color: var(--color-border-hairline);
    background: var(--color-surface);
  }

  .featured-card--minimal.featured-card--linked:hover,
  .featured-card--minimal.featured-card--linked:focus-visible {
    transform: translateX(0.2rem);
  }

  /* =========================================================
     Media — sits at the top of the card. Image crops to a
     consistent aspect ratio. Hover lifts the image and
     reveals a hairline inset frame.
     ========================================================= */
  .featured-card__media {
    position: relative;
    margin: 0;
    background: var(--color-product-image-ground, var(--color-surface-muted));
    overflow: hidden;
    border-radius: calc(var(--radius-card-lg) - 6px);
  }

  .featured-card--has-image .featured-card__media {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .featured-card__media::before {
    content: '';
    position: absolute;
    inset: 0.85rem;
    z-index: 1;
    border: 1px solid rgb(255 255 255 / 0.45);
    opacity: 0;
    pointer-events: none;
    transform: scale(0.99);
    border-radius: calc(var(--radius-card-lg) - 8px);
    transition:
      opacity var(--duration-base) var(--ease-soft),
      transform var(--duration-slow) var(--ease-out);
  }

  .featured-card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to top, rgb(20 20 20 / 0.08), transparent 38%);
    opacity: 0.5;
    transition: opacity var(--duration-base) var(--ease-soft);
  }

  .featured-card__image {
    display: block;
    width: 100%;
    height: 100%;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .featured-card__image--fit-cover {
    object-fit: cover;
  }
  .featured-card__image--fit-contain {
    object-fit: contain;
  }

  .featured-card--linked:hover .featured-card__image,
  .featured-card--linked:focus-visible .featured-card__image {
    transform: scale(1.03);
  }

  .featured-card--linked:hover .featured-card__media::after,
  .featured-card--linked:focus-visible .featured-card__media::after {
    opacity: 0.65;
  }

  .featured-card--linked:hover .featured-card__media::before,
  .featured-card--linked:focus-visible .featured-card__media::before {
    opacity: 1;
    transform: scale(1);
  }

  /* Decorative corner mark — small editorial stamp. */
  .featured-card__media-corner {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    width: 0.6rem;
    height: 0.6rem;
    border-top: 1px solid rgb(255 255 255 / 0.7);
    border-right: 1px solid rgb(255 255 255 / 0.7);
    z-index: 2;
  }

  /* Caption — sits at the bottom-left of the media block. */
  .featured-card__caption {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 2;
    padding: 0.35rem 0.6rem;
    color: var(--color-ink);
    background: rgb(255 255 255 / 0.86);
    border: 1px solid var(--color-border-hairline);
    border-radius: var(--radius-control);
    backdrop-filter: blur(6px);
  }

  /* =========================================================
     Body — flex column. Gap keeps the rhythm consistent
     regardless of whether the eyebrow or index is present.
     ========================================================= */
  .featured-card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex: 1 1 auto;
    min-width: 0;
  }

  /* Image cards need a body padding once again. */
  .featured-card--has-image .featured-card__body {
    padding: 1.65rem 1.5rem 1.5rem;
  }

  .featured-card__top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 0.4rem;
    padding-bottom: 0.95rem;
    border-bottom: 1px solid var(--color-border-hairline);
  }

  .featured-card--align-center .featured-card__top {
    justify-content: center;
  }

  .featured-card__index {
    color: var(--color-ink-soft);
    font-variant-numeric: lining-nums tabular-nums;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--color-border-hairline);
    background: var(--color-surface);
    border-radius: 4px;
  }

  .featured-card__kicker {
    color: var(--color-muted);
    border-left: 1px solid var(--color-border-hairline);
    padding-left: 0.85rem;
  }

  .featured-card__eyebrow {
    color: var(--color-ink-soft);
    margin: 0;
  }

  .featured-card__title {
    color: var(--color-ink);
    text-wrap: balance;
    transition:
      color var(--duration-base) var(--ease-soft),
      transform var(--duration-base) var(--ease-out);
  }

  .featured-card--linked:hover .featured-card__title,
  .featured-card--linked:focus-visible .featured-card__title {
    color: var(--color-ink);
    transform: translateX(0.12rem);
  }

  .featured-card__description {
    max-width: 36ch;
    flex: 1 1 auto;
    min-width: 0;
  }

  .featured-card__meta {
    color: var(--color-muted);
    border-top: 1px solid var(--color-border-hairline);
    padding-top: 0.7rem;
    margin-top: 0.2rem;
  }

  /* =========================================================
     Rail — composed of a hairline that extends into a small
     arrow on hover. Reads as a "→" hand-drawn tail.
     ========================================================= */
  .featured-card__rail {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.4rem;
    color: var(--color-ink);
  }

  .featured-card__rail-line {
    display: block;
    width: 1.6rem;
    height: 1px;
    background: currentColor;
    transform-origin: left center;
    transition:
      width var(--duration-slow) var(--ease-out),
      opacity var(--duration-base) var(--ease-soft);
    opacity: 0.7;
  }

  .featured-card__rail-arrow {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-top: 1px solid currentColor;
    border-right: 1px solid currentColor;
    transform: rotate(45deg) translateX(-2px);
    opacity: 0;
    transition:
      opacity var(--duration-base) var(--ease-soft),
      transform var(--duration-base) var(--ease-out);
  }

  .featured-card--linked:hover .featured-card__rail,
  .featured-card--linked:focus-visible .featured-card__rail {
    color: var(--color-ink);
  }

  .featured-card--linked:hover .featured-card__rail-line,
  .featured-card--linked:focus-visible .featured-card__rail-line {
    width: 2.6rem;
    opacity: 1;
  }

  .featured-card--linked:hover .featured-card__rail-arrow,
  .featured-card--linked:focus-visible .featured-card__rail-arrow {
    opacity: 1;
    transform: rotate(45deg) translateX(0);
  }

  /* =========================================================
     Focus ring — tokenized, generous offset.
     ========================================================= */
  .featured-card--linked:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card,
    .featured-card__frame,
    .featured-card::after,
    .featured-card__image,
    .featured-card__media::after,
    .featured-card__media::before,
    .featured-card__rail-line,
    .featured-card__rail-arrow {
      transition-duration: 1ms;
    }

    .featured-card--linked:hover,
    .featured-card--linked:focus-visible {
      transform: none;
    }
  }
</style>
