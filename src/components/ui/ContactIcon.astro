---
import type { ContactChannelIcon } from '@/data/contact';

interface Props {
  icon: ContactChannelIcon;
}

const { icon } = Astro.props;
---

{
  icon === 'email' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="2.5" y="5.5" width="19" height="13" rx="2" />
      <path d="M3 7.5l9 6 9-6" />
    </svg>
  )
}
{
  icon === 'phone' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="6" y="2.5" width="12" height="19" rx="3" />
      <line x1="10.5" y1="18.5" x2="13.5" y2="18.5" />
    </svg>
  )
}
{
  icon === 'location' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 22s-7-7.5-7-13a7 7 0 0 1 14 0c0 5.5-7 13-7 13z" />
      <circle cx="12" cy="9" r="2.5" />
    </svg>
  )
}
