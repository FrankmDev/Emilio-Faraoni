---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="max-w-3xl">
  {
    eyebrow && (
      <p class="eyebrow">
        {eyebrow}
      </p>
    )
  }
  <h2 class="heading-section mt-4 text-ink">
    {title}
  </h2>
  {
    description && (
      <p class="copy-lead mt-5 max-w-2xl">
        {description}
      </p>
    )
  }
</header>
