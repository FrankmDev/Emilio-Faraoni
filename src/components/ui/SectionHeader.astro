---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="max-w-3xl">
  {
    eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wide text-leather">
        {eyebrow}
      </p>
    )
  }
  <h2
    class="mt-3 text-3xl font-semibold leading-tight tracking-normal text-ink md:text-4xl"
  >
    {title}
  </h2>
  {
    description && (
      <p class="mt-4 text-base leading-7 text-muted md:text-lg">
        {description}
      </p>
    )
  }
</header>
