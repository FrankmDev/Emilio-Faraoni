---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'ghost';
  class?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  class: className,
} = Astro.props;

const classes = `inline-flex min-h-10 items-center justify-center border px-6 text-[0.8125rem] font-normal tracking-[0.02em] transition-colors duration-300 ${
  variant === 'primary'
    ? 'border-ink bg-ink text-bg hover:bg-ink-soft hover:border-ink-soft'
    : variant === 'secondary'
    ? 'border-border bg-transparent text-ink hover:border-ink hover:bg-transparent'
    : 'border-transparent bg-transparent text-muted hover:text-ink'
} ${className || ''}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
