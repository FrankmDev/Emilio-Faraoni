---
import { cn } from '@/lib/utils';

interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'ghost';
  class?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  class: className,
} = Astro.props;

const classes = cn(
  'inline-flex min-h-11 items-center justify-center rounded-sm border px-5 text-sm font-semibold transition-colors',
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-leather',
  variant === 'primary' &&
    'border-leather-dark bg-leather-dark text-white hover:bg-leather',
  variant === 'secondary' &&
    'border-border bg-surface text-ink hover:border-leather',
  variant === 'ghost' &&
    'border-transparent bg-transparent text-leather-dark hover:bg-white/50',
  className,
);
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
