---
interface Props {
  size?: 8 | 10;
  class?: string;
}

const { size = 10, class: className } = Astro.props;
---

<span class={className} aria-hidden="true">
  <svg
    width={size}
    height={size}
    viewBox="0 0 10 10"
    fill="none"
    stroke="currentColor"
    stroke-width="0.55"
    stroke-linecap="round"
  >
    <line x1="0" y1="5" x2="10" y2="5"></line>
    <line x1="5" y1="0" x2="5" y2="10"></line>
  </svg>
</span>
