---
/**
 * BlogGrid · editorial grid for blog cards.
 * Variants:
 *   - 'default'        — 1 / 2 / 3 columns, even grid
 *   - 'featured-first' — first card leads (1.55fr on desktop,
 *                        spans full width on smaller screens)
 *   - 'list'           — single column with hairline dividers
 *                        between rows, no media cropping
 * The first <slot /> child in a 'featured-first' grid
 * renders at the .blog-card--featured scale; the rest stack
 * underneath. Consumers can also pass a `BlogCard` with the
 * `variant="featured"` prop directly into a 'default' grid
 * for the same effect.
 */

type Variant = 'default' | 'featured-first' | 'list';

interface Props {
  variant?: Variant;
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const classes = [
  'blog-grid',
  variant !== 'default' && `blog-grid--${variant}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={classes}>
  <slot />
</div>
