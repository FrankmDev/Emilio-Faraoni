---
import ImagePlaceholder from '@/components/ui/ImagePlaceholder.astro';

interface Props {
  title: string;
  excerpt: string;
  href: string;
  category?: string;
  date?: string;
  readingTime?: string;
  image?: string;
  imageAlt?: string;
  class?: string;
}

const {
  title,
  excerpt,
  href,
  category,
  date,
  readingTime,
  image,
  imageAlt,
  class: className,
} = Astro.props;

const metaItems = [category, date, readingTime].filter(
  (item): item is string => typeof item === 'string' && item.length > 0,
);

const classes = [
  'blog-card',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<article class={classes}>
  <a href={href} class="blog-card__link" aria-label={title}>
    <div class="blog-card__media">
      {
        image ? (
          <img
            src={image}
            alt={imageAlt ?? ''}
            class="blog-card__image"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <ImagePlaceholder
            variant="wide"
            tone="muted"
            label={category ?? title}
            class="blog-card__placeholder"
          />
        )
      }
    </div>
  </a>
  <div class="blog-card__body">
    {
      metaItems.length > 0 && (
        <div class="blog-card__meta" aria-label="Metadatos">
          {metaItems.map((item) => (
            <span class="label-fine">{item}</span>
          ))}
        </div>
      )
    }
    <h3 class="heading-card blog-card__title">
      <a href={href} class="blog-card__title-link">
        {title}
      </a>
    </h3>
    <p class="copy-small blog-card__excerpt">{excerpt}</p>
    <span class="blog-card__rail" aria-hidden="true"></span>
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;
  }

  .blog-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .blog-card__media {
    position: relative;
    overflow: hidden;
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border-hairline);
    border-radius: var(--radius-card);
  }

  .blog-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .blog-card__placeholder {
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: var(--radius-card);
  }

  .blog-card__link:hover .blog-card__image,
  .blog-card__link:focus-visible .blog-card__image {
    transform: scale(1.02);
  }

  .blog-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
    color: var(--color-muted);
  }

  .blog-card__meta > * + *::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.4;
    margin-right: 1rem;
  }

  .blog-card__title {
    color: var(--color-ink);
    margin: 0;
    text-wrap: balance;
  }

  .blog-card__title-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-soft);
  }

  .blog-card__title-link:hover,
  .blog-card__title-link:focus-visible {
    color: var(--color-leather-dark);
  }

  .blog-card__excerpt {
    max-width: 44ch;
  }

  .blog-card__rail {
    display: block;
    width: 1.5rem;
    height: 1px;
    background: var(--color-ink);
    margin-top: 0.4rem;
    transition: width var(--duration-slow) var(--ease-out);
  }

  .blog-card__link:hover ~ .blog-card__body .blog-card__rail,
  .blog-card__title-link:hover ~ .blog-card__rail,
  .blog-card__title-link:focus-visible ~ .blog-card__rail {
    width: 3rem;
  }

  /* Focus ring */
  .blog-card__link:focus-visible,
  .blog-card__title-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }
</style>
