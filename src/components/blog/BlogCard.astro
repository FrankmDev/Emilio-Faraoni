---
/**
 * BlogCard · editorial open card for the blog index.
 * The image is the protagonist; the body is type only — no
 * closed box, no surface fill. Supports four variants:
 *   - default : standard grid card, 4/5 portrait cover
 *   - featured: lead article in a featured-first grid, 5/4
 *   - compact : smaller thumbnail (3/2) for sidebars/rails
 *   - row     : horizontal layout for list views (image left)
 * A magazine-style "N° 01" numeral can be stamped on the
 * cover, and a category cover-tag can be shown at the bottom
 * of the cover when no excerpt is desired.
 *
 * All visual tokens live in src/styles/global.css under
 * `.blog-card*`.
 */
import ImagePlaceholder from '@/components/ui/ImagePlaceholder.astro';

type Variant = 'default' | 'featured' | 'compact' | 'row';

interface Props {
  title: string;
  excerpt?: string;
  href: string;
  category?: string;
  date?: string;
  readingTime?: string;
  author?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number | string;
  imageHeight?: number | string;
  /** Visual variant. Defaults to 'default'. */
  variant?: Variant;
  /** Optional numeral to stamp on the cover, e.g. "N° 01". */
  number?: string;
  /** Optional tag for the bottom-left of the cover. */
  coverTag?: string;
  /** When true, the cover tag is rendered in dark ink for
   *  stronger contrast (used for lead article). */
  coverTagDark?: boolean;
  class?: string;
}

const {
  title,
  excerpt,
  href,
  category,
  date,
  readingTime,
  author,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  variant = 'default',
  number,
  coverTag,
  coverTagDark = false,
  class: className,
} = Astro.props;

const cardClasses = [
  'blog-card',
  variant !== 'default' && `blog-card--${variant}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const isRow = variant === 'row';
const isFeatured = variant === 'featured';
const showExcerpt =
  Boolean(excerpt) && (isFeatured || variant === 'default' || isRow);
const showCoverTag =
  !coverTag && category && !showExcerpt ? category : coverTag;
// When the cover tag is showing the category, the body meta
// should not repeat it.
const showCategoryInMeta = Boolean(category) && !showCoverTag;
const hasBodyMeta =
  showCategoryInMeta ||
  Boolean(author) ||
  Boolean(date) ||
  Boolean(readingTime);

// Defaults per variant — keeps the placeholder aspect ratio
// in sync with the real cover ratio.
const placeholderVariant = isRow
  ? 'wide'
  : isFeatured
    ? 'wide'
    : variant === 'compact'
      ? 'wide'
      : 'portrait';
---

<article class={cardClasses}>
  {
    number && (
      <span
        class:list={[
          'blog-card-numeral',
          coverTagDark && 'blog-card-numeral--ink',
        ]}
        aria-hidden="true"
      >
        {number}
      </span>
    )
  }

  <a href={href} class="blog-card-media focus-ring" aria-label={title}>
    {
      image ? (
        <img
          src={image}
          alt={imageAlt ?? ''}
          width={imageWidth}
          height={imageHeight}
          loading="lazy"
          decoding="async"
          fetchpriority="low"
          class="transition-media"
        />
      ) : (
        <ImagePlaceholder
          variant={placeholderVariant}
          tone="muted"
          crossed={false}
          frame="minimal"
          label={category ?? title}
          class="blog-card-media__placeholder"
        />
      )
    }

    {showCoverTag && <span class="blog-card-cover-tag">{showCoverTag}</span>}
  </a>

  <div class="blog-card-body">
    {
      hasBodyMeta && (
        <ul class="fine-meta blog-card-meta" aria-label="Metadatos">
          {showCategoryInMeta && (
            <li class="blog-card-meta__category">{category}</li>
          )}
          {author && <li>{author}</li>}
          {date && <li>{date}</li>}
          {readingTime && <li>{readingTime}</li>}
        </ul>
      )
    }

    <h3 class="blog-card-title">
      <a href={href}>{title}</a>
    </h3>

    {showExcerpt && <p class="blog-card-excerpt">{excerpt}</p>}

    <a href={href} class="blog-card-link">
      <span>Leer artículo</span>
    </a>
  </div>
</article>
