<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Work+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>Emilio Faraoni</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  :root {
    color-scheme: light;

    /* === Surface tokens === */
    --color-bg: #faf9f6;
    --color-surface: #ffffff;
    --color-surface-muted: #f5f3ee;
    --color-surface-soft: #f0ede7;

    /* === Text tokens === */
    --color-ink: #1a1815;
    --color-ink-soft: #3d3a35;
    --color-muted: #8a8580;
    --color-muted-light: #b8b4ad;

    /* === Border tokens === */
    --color-border: #e8e4dd;
    --color-border-soft: #f0ede7;

    /* === Accent tokens === */
    --color-leather: #b8a48a;
    --color-leather-dark: #6b5f4f;
    --color-leather-light: #d4c4b0;
    --color-gold-soft: #c9a87c;
    --color-sand: #e8e0d4;

    /* === Radius === */
    --radius-card: 2px;
    --radius-control: 2px;
    --radius-pill: 999px;

    /* === Container === */
    --container-max: 77.5rem;

    /* === Spacing === */
    --section-y: clamp(4rem, 8vw, 7.5rem);
    --section-y-compact: clamp(3rem, 5vw, 5rem);
    --grid-gap: clamp(1.25rem, 2.2vw, 2rem);

    /* === Type scale === */
    --type-display: clamp(3.5rem, 9vw, 7.5rem);
    --type-h1: clamp(2.75rem, 7vw, 5.5rem);
    --type-h2: clamp(2.25rem, 5vw, 4rem);
    --type-h3: clamp(1.5rem, 2.5vw, 2.25rem);
    --type-h4: clamp(1.125rem, 1.5vw, 1.375rem);
    --type-body: 1rem;
    --type-small: 0.875rem;
    --type-eyebrow: 0.6875rem;

    /* === Fonts === */
    --font-serif: 'Cormorant Garamond', 'Libre Baskerville', Georgia, 'Times New Roman', serif;
    --font-sans: 'Work Sans', 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* === Base layer === */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    min-height: 100%;
    background: var(--color-bg);
    scroll-behavior: smooth;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    margin: 0;
    background: var(--color-bg);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--type-body);
    font-weight: 400;
    line-height: 1.65;
    letter-spacing: -0.005em;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  picture,
  svg {
    display: block;
    max-width: 100%;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  button {
    cursor: pointer;
    background: none;
    border: none;
  }

  ::selection {
    background: rgba(184, 164, 138, 0.2);
    color: var(--color-ink);
  }

  :focus-visible {
    outline: 1px solid var(--color-leather-dark);
    outline-offset: 3px;
  }

  [hidden] {
    display: none !important;
  }

  /* === Headings === */
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  h1 {
    font-size: var(--type-h1);
    line-height: 1.0;
    font-weight: 300;
  }

  h2 {
    font-size: var(--type-h2);
    line-height: 1.05;
    font-weight: 300;
  }

  h3 {
    font-size: var(--type-h3);
    line-height: 1.15;
    font-weight: 400;
  }

  h4 {
    font-size: var(--type-h4);
    line-height: 1.25;
    font-weight: 400;
    font-family: var(--font-sans);
    letter-spacing: -0.01em;
  }

  p {
    margin: 0;
    line-height: 1.65;
  }

  /* === Utility classes === */
  .section-y {
    padding-block: var(--section-y);
  }

  .section-y-compact {
    padding-block: var(--section-y-compact);
  }

  .grid-gap {
    gap: var(--grid-gap);
  }

  .surface-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-card);
  }

  .surface-muted {
    background: var(--color-surface-muted);
    border-radius: var(--radius-card);
  }

  .eyebrow {
    color: var(--color-leather-dark);
    font-family: var(--font-sans);
    font-size: var(--type-eyebrow);
    font-weight: 500;
    letter-spacing: 0.18em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .meta-label {
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: var(--type-eyebrow);
    font-weight: 500;
    letter-spacing: 0.15em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .copy-lead {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-ink-soft);
    letter-spacing: 0;
  }

  .copy-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--color-ink-soft);
  }

  .copy-small {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .copy-italic {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }

  .display-serif {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: var(--type-display);
    line-height: 0.95;
    letter-spacing: -0.03em;
  }

  .heading-section {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: var(--type-h2);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .heading-card {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: var(--type-h3);
    line-height: 1.15;
    letter-spacing: -0.015em;
  }
</style>
